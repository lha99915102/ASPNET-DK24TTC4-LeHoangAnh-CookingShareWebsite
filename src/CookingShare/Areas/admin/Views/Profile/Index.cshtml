@model CookingShare.Models.PROFILE
@{
    ViewBag.Title = "Hồ sơ Cá nhân";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var account = ViewBag.Account as CookingShare.Models.ACCOUNT;

    // Xử lý đường dẫn Avatar
    string avatarUrl = string.IsNullOrEmpty(Model.Avatar) ? "https://placehold.co/150x150" : "/Content/Images/Users/" + Model.Avatar;
}

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show mb-4"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show mb-4"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="row">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body text-center py-5">
                <div class="position-relative d-inline-block mb-3">
                    <img id="avatarPreview" src="@avatarUrl" class="rounded-circle border border-4 border-white shadow-sm object-fit-cover" style="width: 150px; height: 150px;" alt="Profile Image" onerror="this.src='https://placehold.co/150x150'">
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted mb-3">@@@account.UserName</p>
                <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="fas fa-shield-alt me-1"></i> Quản trị viên (Super Admin)</span>
            </div>
            <div class="card-footer bg-white border-top-0 px-4 pb-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted fw-bold small">Ngày tham gia:</span>
                    <span class="text-dark small">@(account.RegistDate.HasValue ? account.RegistDate.Value.ToString("dd/MM/yyyy") : "N/A")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted fw-bold small">Trạng thái:</span>
                    <span class="text-success fw-bold small"><i class="fas fa-circle me-1" style="font-size: 10px;"></i> Đang hoạt động</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <ul class="nav nav-tabs fw-bold" id="profileTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active text-dark" data-bs-toggle="tab" data-bs-target="#edit-profile" type="button" role="tab"><i class="fas fa-user-edit me-2"></i>Chỉnh sửa thông tin</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link text-dark" data-bs-toggle="tab" data-bs-target="#change-password" type="button" role="tab"><i class="fas fa-key me-2"></i>Đổi mật khẩu</button>
                    </li>
                </ul>
            </div>

            <div class="card-body p-4">
                <div class="tab-content" id="profileTabContent">

                    <div class="tab-pane fade show active" id="edit-profile" role="tabpanel">
                        <form action="/Admin/Profile/UpdateProfile" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <h6 class="text-uppercase text-muted fw-bold mb-3 small">Thông tin cá nhân</h6>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Họ và tên</label>
                                    <input type="text" class="form-control" name="FullName" value="@Model.FullName" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Giới tính</label>
                                    <select class="form-select" name="Gender">
                                        <option value="Nam" @(Model.Gender == "Nam" ? "selected" : "")>Nam</option>
                                        <option value="Nữ" @(Model.Gender == "Nữ" ? "selected" : "")>Nữ</option>
                                        <option value="Khác" @(Model.Gender == "Khác" ? "selected" : "")>Khác</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tài khoản (Username)</label>
                                    <input type="text" class="form-control bg-light" value="@account.UserName" readonly disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Đổi Ảnh đại diện</label>
                                    <input type="file" class="form-control" name="AvatarFile" accept="image/*" onchange="previewImage(this)">
                                </div>
                            </div>

                            <h6 class="text-uppercase text-muted fw-bold mb-3 small mt-4">Thông tin liên hệ</h6>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="email" class="form-control" name="Email" value="@account.Email">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Số điện thoại</label>
                                    <input type="text" class="form-control" name="Phone" value="@account.Phone">
                                </div>
                            </div>

                            <h6 class="text-uppercase text-muted fw-bold mb-3 small mt-4">Giới thiệu (Bio)</h6>
                            <div class="mb-4">
                                <textarea class="form-control" name="Bio" rows="4" placeholder="Viết một chút về bản thân bạn...">@Model.Bio</textarea>
                            </div>

                            <div class="text-end mt-4">
                                <button type="submit" class="btn btn-primary fw-bold px-4 py-2"><i class="fas fa-save me-2"></i> Lưu thay đổi</button>
                            </div>
                        </form>
                    </div>

                    <div class="tab-pane fade" id="change-password" role="tabpanel">
                        <form action="/Admin/Profile/ChangePassword" method="post">
                            @Html.AntiForgeryToken()

                            <div class="alert alert-info border-0 small mb-4">
                                <i class="fas fa-info-circle me-2"></i> Để đảm bảo an toàn, vui lòng sử dụng mật khẩu có ít nhất 6 ký tự, bao gồm cả chữ và số.
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                                <input type="password" class="form-control" name="OldPassword" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mật khẩu mới</label>
                                <input type="password" class="form-control" name="NewPassword" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Xác nhận mật khẩu mới</label>
                                <input type="password" class="form-control" name="ConfirmPassword" required>
                            </div>

                            <div class="text-end mt-4">
                                <button type="submit" class="btn btn-danger fw-bold px-4 py-2"><i class="fas fa-key me-2"></i> Cập nhật Mật khẩu</button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiển thị ảnh Avatar ngay lập tức khi Admin chọn file
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}