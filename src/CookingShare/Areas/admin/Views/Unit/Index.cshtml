@model IEnumerable<CookingShare.Models.UNIT>
@{
    ViewBag.Title = "Quản lý Đơn vị đo lường";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    int stt = 1;
}

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show mb-3"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show mb-3"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm border">
    <h5 class="mb-0 fw-bold text-secondary"><i class="fas fa-balance-scale text-info me-2"></i>Danh sách Đơn vị chuẩn</h5>
    <button class="btn btn-primary" onclick="resetUnitForm()" data-bs-toggle="modal" data-bs-target="#unitModal">
        <i class="fas fa-plus-circle me-2"></i>Thêm Đơn Vị
    </button>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <table class="table table-hover align-middle datatable" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 60px;">TT</th>
                            <th>Tên Đơn vị (Ký hiệu)</th>
                            <th class="text-end" style="width: 150px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-light text-dark border">@(stt++)</span></td>
                                    <td>
                                        <h6 class="mb-0 fw-bold text-dark">@item.UnitName</h6>
                                        <small class="text-muted">ID: @item.ID</small>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"
                                                onclick="editUnit(@item.ID, '@item.UnitName')">
                                            <i class="fas fa-edit"></i>
                                        </button>

                                        <form action="/Admin/Unit/Delete" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa đơn vị này không?');">
                                            <input type="hidden" name="id" value="@item.ID" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="unitModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="modalTitle"><i class="fas fa-balance-scale me-2"></i>Thêm Đơn Vị Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Admin/Unit/Save" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID" id="u_ID" value="0" />

                <div class="modal-body bg-light">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="mb-2">
                                <label class="form-label fw-bold">Tên Đơn vị (Ký hiệu) <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="UnitName" id="u_UnitName" placeholder="VD: gram, kg, ml, muỗng cà phê..." required>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Lưu Dữ Liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetUnitForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="fas fa-balance-scale me-2"></i>Thêm Đơn Vị Mới';
            document.getElementById('u_ID').value = "0";
            document.getElementById('u_UnitName').value = "";
        }

        function editUnit(id, name) {
            resetUnitForm();
            document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Cập Nhật Đơn Vị';
            document.getElementById('u_ID').value = id;
            document.getElementById('u_UnitName').value = name;

            var myModal = new bootstrap.Modal(document.getElementById('unitModal'));
            myModal.show();
        }
    </script>
}