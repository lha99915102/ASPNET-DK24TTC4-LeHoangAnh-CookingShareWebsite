@model IEnumerable<CookingShare.Models.SYSTEM_SETTING>
@{
    ViewBag.Title = "Cấu hình Website";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    int stt = 1;
}

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show mb-3"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show mb-3"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm border">
    <div>
        <h5 class="mb-0 fw-bold text-secondary"><i class="fas fa-cogs text-secondary me-2"></i>Tham số hệ thống</h5>
        <small class="text-muted">Quản lý các biến môi trường, thông tin liên hệ và hình ảnh mặc định.</small>
    </div>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#settingModal" onclick="resetSettingForm()">
        <i class="fas fa-plus-circle me-2"></i>Thêm Cấu hình mới
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle datatable" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">TT</th>
                    <th style="width: 250px;">Mã Cấu Hình (SettingKey)</th>
                    <th>Giá Trị (SettingValue)</th>
                    <th class="text-end" style="width: 120px;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        // Xử lý chuỗi an toàn khi truyền vào JavaScript
                        string safeValue = System.Web.HttpUtility.JavaScriptStringEncode(item.SettingValue ?? "");

                        <tr>
                            <td><span class="badge bg-light text-dark border">@(stt++)</span></td>
                            <td>
                                <span class="fw-bold text-primary font-monospace">@item.SettingKey</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.SettingValue) && (item.SettingValue.Contains(".jpg") || item.SettingValue.Contains(".png") || item.SettingValue.Contains("http")))
                                {
                                    <div class="d-flex align-items-center">
                                        <img src="@item.SettingValue" class="rounded border me-2 object-fit-cover" style="height: 40px; width: 80px;" onerror="this.style.display='none'">
                                        <span class="text-truncate d-inline-block text-muted small" style="max-width: 300px;">@item.SettingValue</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-truncate d-inline-block text-dark" style="max-width: 400px;">@item.SettingValue</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1"
                                        onclick="editSetting(@item.ID, '@item.SettingKey', `@safeValue`)">
                                    <i class="fas fa-edit"></i>
                                </button>

                                <form action="@Url.Action("Delete", "Setting", new { area = "Admin" })" method="post" style="display:inline;" onsubmit="return confirm('Xóa cấu hình này có thể gây lỗi hệ thống. Bạn có chắc chắn?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ID" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="settingModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold" id="modalTitle"><i class="fas fa-cog me-2"></i>Thêm Cấu Hình</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="@Url.Action("Save", "Setting", new { area = "Admin" })" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID" id="s_ID" value="0" />

                <div class="modal-body bg-light">
                    <div class="alert alert-warning small py-2 mb-3">
                        <i class="fas fa-exclamation-triangle me-1"></i> Không nên thay đổi <strong>Mã cấu hình (Key)</strong> nếu không hiểu rõ mã nguồn.
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mã cấu hình (Key) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" name="SettingKey" id="s_Key" placeholder="VD: Hotline, SiteName, Cover_Image..." required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Giá trị (Value) <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="SettingValue" id="s_Value" rows="4" placeholder="Nhập giá trị text hoặc copy đường dẫn hình ảnh dán vào đây..." required></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Lưu Dữ Liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetSettingForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="fas fa-cog me-2"></i>Thêm Cấu Hình Mới';
            document.getElementById('s_ID').value = "0";
            document.getElementById('s_Key').value = "";
            document.getElementById('s_Value').value = "";
        }

        function editSetting(id, key, value) {
            resetSettingForm();
            document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Cập Nhật Cấu Hình';
            document.getElementById('s_ID').value = id;
            document.getElementById('s_Key').value = key;
            document.getElementById('s_Value').value = value;

            // chống kẹt Modal Backdrop
            var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('settingModal'));
            myModal.show();
        }
    </script>
}