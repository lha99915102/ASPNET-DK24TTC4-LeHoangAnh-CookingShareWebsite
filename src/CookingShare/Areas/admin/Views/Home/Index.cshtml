@model IEnumerable<CookingShare.Models.RECIPE>

@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* CSS để khi hover vào thẻ Card sẽ có hiệu ứng nổi lên, không bị đổi màu chữ */
    .stat-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .stat-link:hover .stat-card {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show mb-4"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show mb-4"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <a href="@Url.Action("Index", "Recipe", new { area = "Admin" })" class="stat-link h-100">
            <div class="stat-card card h-100 border-start border-4 border-primary shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1 text-uppercase fw-bold">Tổng Công thức</p>
                            <h3 class="fw-bold mb-0">@ViewBag.TotalRecipes</h3>
                        </div>
                        <div class="icon-box bg-primary bg-opacity-10 text-primary p-3 rounded">
                            <i class="fas fa-utensils fs-4"></i>
                        </div>
                    </div>
                    <small class="text-success small mt-2 d-block"><i class="fas fa-arrow-up"></i> Quản lý tất cả</small>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a href="@Url.Action("Index", "Recipe", new { area = "Admin", statusFilter = 0 })" class="stat-link h-100">
            <div class="stat-card card h-100 border-start border-4 border-danger shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1 text-uppercase fw-bold">Cần Duyệt Gấp</p>
                            <h3 class="fw-bold mb-0 text-danger">@ViewBag.PendingRecipesCount</h3>
                        </div>
                        <div class="icon-box bg-danger bg-opacity-10 text-danger p-3 rounded">
                            <i class="fas fa-tasks fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-2 small">
                        <span class="badge bg-danger">@ViewBag.PendingRecipesCount bài chờ duyệt</span>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a href="@Url.Action("Index", "Ingredient", new { area = "Admin" })" class="stat-link h-100">
            <div class="stat-card card h-100 border-start border-4 border-success shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1 text-uppercase fw-bold">Nguyên liệu</p>
                            <h3 class="fw-bold mb-0">@ViewBag.TotalIngredients</h3>
                        </div>
                        <div class="icon-box bg-success bg-opacity-10 text-success p-3 rounded">
                            <i class="fas fa-carrot fs-4"></i>
                        </div>
                    </div>
                    <small class="text-muted small mt-2 d-block">Đã chuẩn hóa dữ liệu</small>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a href="@Url.Action("Index", "User", new { area = "Admin" })" class="stat-link h-100">
            <div class="stat-card card h-100 border-start border-4 border-info shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted small mb-1 text-uppercase fw-bold">Thành viên</p>
                            <h3 class="fw-bold mb-0">@ViewBag.TotalUsers</h3>
                        </div>
                        <div class="icon-box bg-info bg-opacity-10 text-info p-3 rounded">
                            <i class="fas fa-users fs-4"></i>
                        </div>
                    </div>
                    <small class="text-success small mt-2 d-block"><i class="fas fa-user-plus"></i> Quản lý cộng đồng</small>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-bolt me-2 text-warning"></i>Thao tác nhanh</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="@Url.Action("Index", "Banner", new { area = "Admin" })" class="btn btn-outline-primary rounded-pill">
                        <i class="fas fa-images me-2"></i>Đổi Slider Trang Chủ
                    </a>
                    <a href="@Url.Action("Index", "Ingredient", new { area = "Admin" })" class="btn btn-outline-warning rounded-pill">
                        <i class="fas fa-plus-circle me-2"></i>Thêm Nguyên Liệu Mới
                    </a>
                    <a href="@Url.Action("Index", "Community", new { area = "Admin" })" class="btn btn-outline-danger rounded-pill">
                        <i class="fas fa-flag me-2"></i>Kiểm Tra Báo Cáo Vi Phạm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold border-bottom-0">
                <i class="fas fa-chart-area me-2 text-primary"></i>Thống kê Tương tác & Bài đăng 6 tháng qua
            </div>
            <div class="card-body">
                <canvas id="mainChart" style="max-height: 350px; width: 100%;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold border-bottom-0 d-flex justify-content-between align-items-center">
                <span><i class="fas fa-bell me-2 text-danger"></i>Việc cần làm</span>
                <a href="@Url.Action("Index", "Recipe", new { area = "Admin", statusFilter = 0 })" class="small text-decoration-none">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            // Lấy FullName của người dùng nếu có
                            string authorName = "Ẩn danh";
                            if (item.ACCOUNT != null)
                            {
                                authorName = (item.ACCOUNT.PROFILE != null && !string.IsNullOrEmpty(item.ACCOUNT.PROFILE.FullName))
                                             ? item.ACCOUNT.PROFILE.FullName
                                             : item.ACCOUNT.UserName;
                            }

                            <div class="list-group-item px-3 py-3 border-bottom-0 border-top">
                                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px;" title="@item.Name">@item.Name</h6>
                                    <span class="badge bg-light text-secondary border">Công thức</span>
                                </div>

                                <p class="mb-2 small text-secondary">
                                    Đăng bởi: <strong>@authorName</strong>
                                    • @(item.CreateDate.HasValue ? item.CreateDate.Value.ToString("dd/MM/yyyy") : "")
                                </p>

                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Approve", "Recipe", new { area = "Admin", id = item.ID })" class="btn btn-sm btn-success py-1 px-3" style="font-size: 0.75rem;" onclick="return confirm('Bạn có chắc chắn muốn DUYỆT công thức này ra trang chủ không?');">Duyệt</a>

                                    <a href="@Url.Action("Detail", "Recipe", new { area = "", id = item.ID })" target="_blank" class="btn btn-sm btn-outline-dark py-1 px-3" style="font-size: 0.75rem;">Xem nội dung</a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                            <p class="mb-0 small">Tuyệt vời! Không có bài viết nào đang chờ duyệt.</p>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Lấy thẻ canvas
            var ctx = document.getElementById('mainChart');
            if (ctx) {
                var context2D = ctx.getContext('2d');

                // Khởi tạo biểu đồ đường (Line Chart)
                var mainChart = new Chart(context2D, {
                    type: 'line',
                    data: {
                        labels: ['Tháng 10', 'Tháng 11', 'Tháng 12', 'Tháng 1', 'Tháng 2', 'Tháng 3'], // Nhãn trục X
                        datasets: [
                            {
                                label: 'Bài đăng Công thức mới',
                                data: [12, 19, 15, 25, 22, 30], // Dữ liệu giả lập (Mock data)
                                borderColor: '#0dcaf0', // Màu xanh info
                                backgroundColor: 'rgba(13, 202, 240, 0.2)',
                                borderWidth: 2,
                                tension: 0.4, // Độ cong của đường biểu đồ
                                fill: true
                            },
                            {
                                label: 'Lượt tương tác (Bình luận, Cooksnap)',
                                data: [45, 60, 50, 80, 75, 110], // Dữ liệu giả lập
                                borderColor: '#ff6600', // Màu cam chủ đạo của web
                                backgroundColor: 'rgba(255, 102, 0, 0.1)',
                                borderWidth: 2,
                                tension: 0.4,
                                fill: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'top',
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            }
        });
    </script>
}