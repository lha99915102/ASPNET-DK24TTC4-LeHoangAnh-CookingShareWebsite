@model IEnumerable<CookingShare.Models.ACCOUNT>
@{
    ViewBag.Title = "Quản lý Người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    int currentAdminId = ViewBag.CurrentAdminID ?? 0;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-1">Tổng Thành Viên</h6>
                    <h3 class="mb-0 fw-bold">@ViewBag.TotalUsers</h3>
                </div>
                <i class="fas fa-users fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-1">Đang Hoạt Động</h6>
                    <h3 class="mb-0 fw-bold">@ViewBag.ActiveUsers</h3>
                </div>
                <i class="fas fa-user-check fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-danger text-white">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="mb-1">Bị Khóa (Banned)</h6>
                    <h3 class="mb-0 fw-bold">@ViewBag.BannedUsers</h3>
                </div>
                <i class="fas fa-user-lock fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#userModal" onclick="resetUserForm()">
        <i class="fas fa-plus-circle me-2"></i>Thêm Tài khoản
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle datatable" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Đóng góp</th>
                    <th>Ngày tham gia</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    // Lấy Tên hiển thị (Nếu chưa có Profile thì lấy Username)
                    string fullName = item.PROFILE != null ? item.PROFILE.FullName : item.UserName;
                    string avatarUrl = item.PROFILE != null && !string.IsNullOrEmpty(item.PROFILE.Avatar) ? item.PROFILE.Avatar : "default-avatar.png";
                    string bgClass = item.Status == 0 ? "table-danger opacity-75" : "";

                    <tr class="@bgClass">
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="~/Content/Images/Users/@avatarUrl" class="rounded-circle me-2 object-fit-cover" style="width: 40px; height: 40px;" alt="Avatar" onerror="this.src='https://placehold.co/40x40'">
                                <div>
                                    <span class="fw-bold text-dark d-block @(item.Status == 0 ? "text-decoration-line-through" : "")">@fullName</span>
                                    <small class="text-muted">@item.UserName</small>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted @(item.Status == 0 ? "text-decoration-line-through" : "")">@item.Email</td>
                        <td>
                            @if (item.Role == 1)
                            {<span class="badge bg-primary"><i class="fas fa-shield-alt me-1"></i> Quản trị viên</span> }
                            else
                            { <span class="badge bg-secondary">Thành viên</span>}
                        </td>
                        <td>
                            @if (item.Status == 1)
                            {<span class="badge bg-success">Hoạt động</span> }
                            else
                            { <span class="badge bg-danger"><i class="fas fa-ban me-1"></i> Bị khóa</span>}
                        </td>
                        <td><span class="fw-bold">@item.RECIPE.Count</span> công thức</td>
                        <td>@(item.RegistDate.HasValue ? item.RegistDate.Value.ToString("dd/MM/yyyy") : "")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="editUser(@item.ID, '@fullName', '@item.Email', @item.Role, @item.Status)">
                                <i class="fas fa-edit"></i>
                            </button>

                            <form action="/Admin/User/ToggleStatus" method="post" style="display:inline;" onsubmit="return confirm('Đổi trạng thái tài khoản này?');">
                                <input type="hidden" name="id" value="@item.ID" />
                                @if (item.ID == currentAdminId)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Tài khoản của bạn"><i class="fas fa-lock"></i></button>
                                }
                                else if (item.Status == 1)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Khóa tài khoản"><i class="fas fa-lock"></i></button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Mở khóa tài khoản"><i class="fas fa-unlock"></i></button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="modalUserTitle">Cập nhật Người dùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/Admin/User/Save" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID" id="u_ID" value="0" />

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và Tên</label>
                        <input type="text" class="form-control" name="FullName" id="u_FullName" placeholder="VD: Lê Hoàng Anh" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input type="email" class="form-control" name="Email" id="u_Email" placeholder="email@example.com" required>
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label class="form-label fw-bold">Vai trò</label>
                            <select class="form-select" name="Role" id="u_Role">
                                <option value="2">Thành viên (Member)</option>
                                <option value="1">Quản trị viên (Admin)</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            <select class="form-select" name="Status" id="u_Status">
                                <option value="1">Đang hoạt động</option>
                                <option value="0">Khóa (Banned)</option>
                            </select>
                        </div>
                    </div>
                    <div class="alert alert-warning border-0 p-2 small mt-3" id="passwordAlert">
                        <i class="fas fa-exclamation-triangle me-1"></i> Mật khẩu mặc định khi tạo mới là <b>123456</b>.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resetUserForm() {
            document.getElementById('modalUserTitle').innerText = "Thêm Người Dùng Mới";
            document.getElementById('passwordAlert').style.display = "block"; // Hiện nhắc nhở mk mặc định
            document.getElementById('u_ID').value = "0";
            document.getElementById('u_FullName').value = "";
            document.getElementById('u_Email').value = "";
            document.getElementById('u_Role').value = "2"; // Mặc định là Thành viên
            document.getElementById('u_Status').value = "1"; // Mặc định là Hoạt động
        }

        // Bắt sự kiện bấm nút Sửa, lấy dữ liệu đẩy vào Form Modal
        function editUser(id, name, email, role, status) {
            resetUserForm(); // Xóa trắng trước
            document.getElementById('modalUserTitle').innerText = "Cập Nhật Thông Tin";
            document.getElementById('passwordAlert').style.display = "none"; // Ẩn nhắc nhở mật khẩu khi Edit

            document.getElementById('u_ID').value = id;
            document.getElementById('u_FullName').value = name;
            document.getElementById('u_Email').value = email;
            document.getElementById('u_Role').value = role;
            document.getElementById('u_Status').value = status;

            // Bật modal lên
            var myModal = new bootstrap.Modal(document.getElementById('userModal'));
            myModal.show();
        }
    </script>
}
