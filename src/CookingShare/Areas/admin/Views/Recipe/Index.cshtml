@model IEnumerable<CookingShare.Models.RECIPE>
@{
    ViewBag.Title = "Quản lý Công thức";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    int? currentFilter = ViewBag.CurrentFilter as int?;

    var categories = ViewBag.Categories as IEnumerable<CookingShare.Models.CATEGORY>;
    var allTags = ViewBag.AllTags as IEnumerable<CookingShare.Models.TAG>;
    var allIngredients = ViewBag.AllIngredients as IEnumerable<CookingShare.Models.INGREDIENT>;
    var allUnits = ViewBag.AllUnits as IEnumerable<CookingShare.Models.UNIT>;
}

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show mb-3"><i class="fas fa-check-circle me-2"></i> @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show mb-3"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm border-start border-4 border-warning"><div class="card-body"><h5 class="text-muted small text-uppercase fw-bold">Tổng số công thức</h5><h3 class="fw-bold mb-0">@ViewBag.TotalRecipes</h3></div></div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm border-start border-4 border-danger"><div class="card-body"><h5 class="text-muted small text-uppercase fw-bold">Cần duyệt ngay</h5><h3 class="fw-bold mb-0 text-danger">@ViewBag.PendingRecipes</h3></div></div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-2">
        <ul class="nav nav-pills nav-fill">
            <li class="nav-item"><a class="nav-link @(!currentFilter.HasValue ? "active fw-bold bg-primary text-white" : "text-secondary")" href="@Url.Action("Index", "Recipe", new { area = "Admin" })"><i class="fas fa-list me-2"></i>Tất cả</a></li>
            <li class="nav-item">
                <a class="nav-link @(currentFilter == 0 ? "active fw-bold bg-warning text-dark" : "text-secondary")" href="@Url.Action("Index", "Recipe", new { area = "Admin", statusFilter = 0 })">
                    <i class="fas fa-clock me-2"></i>Chờ phê duyệt @if (ViewBag.PendingRecipes > 0)
                    {<span class="badge bg-danger ms-1">@ViewBag.PendingRecipes</span>}
                </a>
            </li>
            <li class="nav-item"><a class="nav-link @(currentFilter == 1 ? "active fw-bold bg-success text-white" : "text-secondary")" href="@Url.Action("Index", "Recipe", new { area = "Admin", statusFilter = 1 })"><i class="fas fa-check-circle me-2"></i>Đã đăng (Public)</a></li>
            <li class="nav-item"><a class="nav-link @(currentFilter == 2 ? "active fw-bold bg-danger text-white" : "text-secondary")" href="@Url.Action("Index", "Recipe", new { area = "Admin", statusFilter = 2 })"><i class="fas fa-ban me-2"></i>Đã từ chối</a></li>
        </ul>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle datatable" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th>Món ăn</th>
                    <th>Người đăng</th>
                    <th>Danh mục</th>
                    <th>Ngày gửi</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    string statusBadge = item.Status == 1 ? "bg-success" : (item.Status == 2 ? "bg-secondary" : "bg-warning text-dark");
                    string statusText = item.Status == 1 ? "Đã duyệt" : (item.Status == 2 ? "Từ chối" : "Chờ duyệt");
                    string imgUrl = string.IsNullOrEmpty(item.MainImage) ? "https://placehold.co/60x60" : (item.MainImage.StartsWith("/") ? item.MainImage : Url.Content("~/assets/images/recipes/" + item.MainImage));

                    string safeUserName = item.ACCOUNT != null ? item.ACCOUNT.UserName : "U";
                    string avatarUrl = $"https://ui-avatars.com/api/?name={safeUserName}&background=random&color=fff";

                    if (item.ACCOUNT != null && item.ACCOUNT.PROFILE != null && !string.IsNullOrEmpty(item.ACCOUNT.PROFILE.Avatar) && item.ACCOUNT.PROFILE.Avatar != "default-avatar.png")
                    {
                        avatarUrl = Url.Content("~/assets/images/avatars/" + item.ACCOUNT.PROFILE.Avatar);
                    }

                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@imgUrl" class="rounded me-3 object-fit-cover border shadow-sm" style="width:60px; height:60px;" alt="Dish" onerror="this.src='https://placehold.co/60x60'">
                                <div><h6 class="mb-0 fw-bold @(item.Status == 0 ? "text-primary" : "text-dark")">@item.Name</h6><small class="text-muted">ID: #REC@(item.ID.ToString("D3"))</small></div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@avatarUrl" class="rounded-circle me-2 object-fit-cover shadow-sm border" style="width:30px; height:30px;" alt="User" onerror="this.src='https://ui-avatars.com/api/?name=U'">
                                <span>@(item.ACCOUNT != null ? item.ACCOUNT.UserName : "Ẩn danh")</span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@(item.CATEGORY != null ? item.CATEGORY.Name : "Chưa phân loại")</span></td>
                        <td>@(item.CreateDate.HasValue ? item.CreateDate.Value.ToString("dd/MM/yyyy") : "")</td>
                        <td><span class="badge @statusBadge status-badge">@statusText</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-primary me-1"
                                    onclick="openEditModal(this)"
                                    data-id="@item.ID"
                                    data-name="@HttpUtility.HtmlEncode(item.Name)"
                                    data-status="@item.Status"
                                    data-category="@item.CategoryID"
                                    data-difficulty="@item.Difficulty"
                                    data-preptime="@item.PrepTime"
                                    data-cooktime="@item.CookTime"
                                    data-servings="@item.Servings"
                                    data-image="@imgUrl"
                                    data-desc="@HttpUtility.HtmlEncode(item.Describe)"
                                    data-reason="@HttpUtility.HtmlEncode(item.RejectReason)">
                                <i class="fas fa-edit"></i> Chỉnh sửa / Duyệt
                            </button>

                            <form action="@Url.Action("Delete", "Recipe", new { area = "Admin" })" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn công thức này cùng toàn bộ bình luận/thành quả của nó?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="hidden-recipe-details-container" class="d-none">
    @foreach (var item in Model)
    {
        <div id="recipe-details-@item.ID">
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                    <h6 class="fw-bold text-primary mb-0"><i class="fas fa-tags me-2"></i>Nhãn dán (Tags)</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary py-0" onclick="addNewItem('tag')"><i class="fas fa-plus me-1"></i>Thêm</button>
                </div>
                <div class="modal-list-tag">
                    @if (item.TAG != null && item.TAG.Any())
                    {
                        foreach (var tag in item.TAG)
                        {
                            <span class="badge bg-secondary me-1 mb-2 existing-item shadow-sm" style="font-size: 14px;">
                                #@tag.TagName
                                <input type="hidden" name="ExistingTagIDs" value="@tag.ID" />
                                <i class="fas fa-times ms-2 text-warning" style="cursor:pointer;" onclick="this.closest('.existing-item').remove()" title="Gỡ tag này"></i>
                            </span>
                        }
                    }
                    else
                    { <p class="text-muted small empty-msg mb-0">Không có tag</p>}
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                    <h6 class="fw-bold text-success mb-0"><i class="fas fa-carrot me-2"></i>Nguyên liệu (Sửa định lượng)</h6>
                    <button type="button" class="btn btn-sm btn-outline-success py-0" onclick="addNewItem('ingredient')"><i class="fas fa-plus me-1"></i>Thêm</button>
                </div>
                <div class="modal-list-ingredient">
                    @if (item.RECIPE_DETAIL != null && item.RECIPE_DETAIL.Any())
                    {
                        foreach (var detail in item.RECIPE_DETAIL)
                        {
                            <div class="input-group input-group-sm mb-2 existing-item shadow-sm">
                                <span class="input-group-text bg-light fw-bold" style="width: 150px;">@(detail.INGREDIENT != null ? detail.INGREDIENT.Name : "N/A")</span>
                                <input type="hidden" name="DetailIngredientIDs" value="@detail.IngredientID" />
                                <input type="number" step="0.01" class="form-control border-success" name="DetailQuantities" value="@detail.Quantity">
                                <span class="input-group-text bg-light" style="width: 80px;">@(detail.UNIT != null ? detail.UNIT.UnitName : "")</span>
                                <button type="button" class="btn btn-outline-danger" onclick="this.closest('.existing-item').remove()"><i class="fas fa-trash"></i></button>
                            </div>
                        }
                    }
                    else
                    { <p class="text-muted small empty-msg mb-0">Chưa có nguyên liệu</p>}
                </div>
            </div>

            <div class="mb-2">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                    <h6 class="fw-bold text-orange mb-0"><i class="fas fa-list-ol me-2"></i>Các bước thực hiện</h6>
                    <button type="button" class="btn btn-sm btn-outline-warning py-0 text-dark fw-bold" onclick="addNewItem('step')"><i class="fas fa-plus me-1"></i>Thêm</button>
                </div>
                <div class="modal-list-step">
                    @if (item.STEPTODO != null && item.STEPTODO.Any())
                    {
                        foreach (var step in item.STEPTODO.OrderBy(s => s.StepOrder))
                        {
                            <div class="card mb-2 border-0 bg-light existing-item shadow-sm">
                                <div class="card-body p-2 d-flex gap-2">
                                    <div class="w-100">
                                        <label class="form-label small fw-bold text-primary">Bước @step.StepOrder:</label>
                                        <input type="hidden" name="StepIDs" value="@step.ID" />
                                        <textarea class="form-control form-control-sm mb-2 border-primary" name="StepContents" rows="2">@step.Content</textarea>
                                        @if (!string.IsNullOrEmpty(step.ImageURL))
                                        {
                                            string stepImgUrl = step.ImageURL.StartsWith("/") ? step.ImageURL : Url.Content("~/assets/images/steps/" + step.ImageURL);
                                            <img src="@stepImgUrl" class="rounded object-fit-cover shadow-sm mt-1" style="max-height: 80px;" alt="Step image" onerror="this.style.display='none'" />
                                        }
                                    </div>
                                    <button type="button" class="btn btn-outline-danger h-100" onclick="this.closest('.existing-item').remove()"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        }
                    }
                    else
                    { <p class="text-muted small empty-msg mb-0">Chưa có hướng dẫn</p>}
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="editRecipeModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold"><i class="fas fa-search me-2"></i>Kiểm duyệt & Chỉnh sửa: <span id="modalTitleName" class="text-primary"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form action="@Url.Action("Edit", "Recipe", new { area = "Admin" })" method="post" enctype="multipart/form-data" id="recipeForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ID" id="m_ID" value="0" />

                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-lg-8 p-4 bg-white border-end">
                            <ul class="nav nav-tabs mb-4" id="recipeTabs" role="tablist">
                                <li class="nav-item"><button class="nav-link active fw-bold text-dark" id="basic-tab" data-bs-toggle="tab" data-bs-target="#basic" type="button">Thông tin cơ bản</button></li>
                                <li class="nav-item"><button class="nav-link fw-bold text-success" id="detail-tab" data-bs-toggle="tab" data-bs-target="#detail" type="button"><i class="fas fa-edit me-1"></i>Chỉnh sửa & Bổ sung</button></li>
                            </ul>

                            <div class="tab-content" id="recipeTabsContent">
                                <div class="tab-pane fade show active" id="basic" role="tabpanel">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small">Tên món ăn <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control fw-bold text-orange" name="Name" id="m_Name" required>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small">Danh mục</label>
                                            <select class="form-select" name="CategoryID" id="m_CategoryID">
                                                <option value="">-- Chọn danh mục --</option>
                                                @if (categories != null)
                                                {
                                                    foreach (var cat in categories)
                                                    {
                                                        <option value="@cat.ID">@cat.Name</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold small">Độ khó</label>
                                            <select class="form-select" name="Difficulty" id="m_Difficulty">
                                                <option value="Dễ">Dễ</option>
                                                <option value="Trung bình">Trung bình</option>
                                                <option value="Khó">Khó</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold small">T/gian sơ chế (phút)</label>
                                            <input type="number" class="form-control" name="PrepTime" id="m_PrepTime">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold small">T/gian nấu (phút)</label>
                                            <input type="number" class="form-control" name="CookTime" id="m_CookTime">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-bold small">Khẩu phần (người)</label>
                                            <input type="number" class="form-control" name="Servings" id="m_Servings">
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold small">Mô tả ngắn</label>
                                        <textarea class="form-control" name="Describe" id="m_Describe" rows="4"></textarea>
                                    </div>

                                    <div class="mb-3 p-3 bg-light border rounded">
                                        <label class="form-label fw-bold text-primary">Thay đổi Ảnh đại diện món ăn</label>
                                        <div class="d-flex align-items-center">
                                            <img id="m_ImagePreview" src="" class="rounded me-3 object-fit-cover shadow-sm border" style="width: 80px; height: 80px; display: none;">
                                            <div class="flex-grow-1">
                                                <input class="form-control form-control-sm" type="file" name="ImageFile" accept="image/*" onchange="previewRecipeImg(this)">
                                                <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle me-1"></i>Để trống nếu muốn giữ nguyên ảnh hiện tại.</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="tab-pane fade" id="detail" role="tabpanel">
                                    <div class="alert alert-info small mb-3"><i class="fas fa-info-circle me-2"></i>Admin có thể chỉnh sửa dữ liệu cũ hoặc bấm nút <b>+ Thêm</b> để chủ động bổ sung nội dung cho bài viết nếu tác giả bỏ trống.</div>
                                    <div id="m_RecipeFullDetails"></div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 bg-light">
                            <div class="p-4 sticky-top" style="z-index: 10;">
                                <h6 class="fw-bold text-uppercase text-secondary mb-3"><i class="fas fa-cog me-2"></i>Bảng Điều Khiển</h6>

                                <div class="card mb-3 border-0 shadow-sm">
                                    <div class="card-body">
                                        <label class="fw-bold small mb-2">Trạng thái hiện tại:</label>
                                        <div id="m_StatusBadge" class="mb-2"></div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="fw-bold small mb-2 text-dark">Chuyển trạng thái sang:</label>
                                    <select class="form-select border-primary fw-bold shadow-sm" name="NewStatus" id="m_NewStatus" onchange="toggleReasonBox()">
                                        <option value="0" class="text-warning fw-bold">Chờ duyệt</option>
                                        <option value="1" class="text-success fw-bold">Phê duyệt (Public)</option>
                                        <option value="2" class="text-danger fw-bold">Từ chối</option>
                                    </select>
                                </div>

                                <div class="mb-4" id="rejectReasonBox" style="display:none;">
                                    <label class="fw-bold small mb-2 text-danger">Lý do từ chối (Bắt buộc):</label>
                                    <textarea class="form-control border-danger" name="rejectReason" id="m_RejectReason" rows="4" placeholder="VD: Công thức không hợp lệ, sai tỷ lệ nguyên liệu..."></textarea>
                                </div>

                                <div class="d-grid gap-2 mt-4">
                                    <button type="submit" class="btn btn-primary fw-bold py-3 mb-2 shadow-sm" onclick="return validateSubmit();">
                                        <i class="fas fa-save me-2"></i> CẬP NHẬT & LƯU
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary py-2" data-bs-dismiss="modal">Đóng cửa sổ</button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="tmpl-tag">
    <div class="input-group input-group-sm mb-2 new-item-row shadow-sm">
        <select class="form-select border-primary" name="NewTagIDs">
            @if (allTags != null)
            {
                foreach (var t in allTags)
                {
                    <option value="@t.ID">@t.TagName</option>
                }
            }
        </select>
        <button type="button" class="btn btn-danger" onclick="this.closest('.new-item-row').remove()"><i class="fas fa-times"></i></button>
    </div>
</template>

<template id="tmpl-ing">
    <div class="input-group input-group-sm mb-2 new-item-row shadow-sm">
        <select class="form-select border-success fw-bold" name="NewIngredientIDs" style="width: 40%;">
            @if (allIngredients != null)
            {
                foreach (var i in allIngredients)
                {
                    <option value="@i.ID">@i.Name</option>
                }
            }
        </select>
        <input type="number" step="0.01" class="form-control border-success" name="NewQuantities" placeholder="Số lượng" required style="width: 25%;">
        <select class="form-select border-success" name="NewUnitIDs" style="width: 25%;">
            @if (allUnits != null)
            {
                foreach (var u in allUnits)
                {
                    <option value="@u.ID">@u.UnitName</option>
                }
            }
        </select>
        <button type="button" class="btn btn-danger" onclick="this.closest('.new-item-row').remove()"><i class="fas fa-times"></i></button>
    </div>
</template>

<template id="tmpl-step">
    <div class="card mb-2 border border-warning bg-light new-item-row shadow-sm">
        <div class="card-body p-2 d-flex gap-2">
            <textarea class="form-control form-control-sm border-warning" name="NewStepContents" rows="2" placeholder="Nhập nội dung bước làm mới..." required></textarea>
            <button type="button" class="btn btn-danger h-100" onclick="this.closest('.new-item-row').remove()"><i class="fas fa-times"></i></button>
        </div>
    </div>
</template>

@section Scripts {
    <script>
        function toggleReasonBox() {
            var statusVal = document.getElementById('m_NewStatus').value;
            var reasonBox = document.getElementById('rejectReasonBox');
            if (statusVal === "2") reasonBox.style.display = 'block';
            else reasonBox.style.display = 'none';
        }

        function addNewItem(type) {
            let tmplId = '';
            let containerClass = '';
            if (type === 'tag') { tmplId = 'tmpl-tag'; containerClass = '.modal-list-tag'; }
            if (type === 'ingredient') { tmplId = 'tmpl-ing'; containerClass = '.modal-list-ingredient'; }
            if (type === 'step') { tmplId = 'tmpl-step'; containerClass = '.modal-list-step'; }

            let tmpl = document.getElementById(tmplId).content.cloneNode(true);
            let container = document.querySelector('#m_RecipeFullDetails ' + containerClass);
            if (container) {
                let emptyMsg = container.querySelector('.empty-msg');
                if (emptyMsg) emptyMsg.remove();
                container.appendChild(tmpl);
            }
        }

        function previewRecipeImg(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = document.getElementById('m_ImagePreview');
                    img.src = e.target.result;
                    img.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function openEditModal(btn) {
            let id = btn.getAttribute('data-id');
            let status = btn.getAttribute('data-status');
            let imgUrl = btn.getAttribute('data-image');

            document.getElementById('m_ID').value = id;

            // Dùng textContent để decode HtmlEncode an toàn
            let tempDiv = document.createElement('div');

            tempDiv.innerHTML = btn.getAttribute('data-name');
            let name = tempDiv.textContent;

            tempDiv.innerHTML = btn.getAttribute('data-desc');
            let desc = tempDiv.textContent;

            tempDiv.innerHTML = btn.getAttribute('data-reason');
            let reason = tempDiv.textContent;

            document.getElementById('modalTitleName').innerText = name;
            document.getElementById('m_Name').value = name;
            document.getElementById('m_CategoryID').value = btn.getAttribute('data-category');
            document.getElementById('m_Difficulty').value = btn.getAttribute('data-difficulty');
            document.getElementById('m_PrepTime').value = btn.getAttribute('data-preptime');
            document.getElementById('m_CookTime').value = btn.getAttribute('data-cooktime');
            document.getElementById('m_Servings').value = btn.getAttribute('data-servings');
            document.getElementById('m_Describe').value = desc;
            document.getElementById('m_RejectReason').value = reason;

            // Xử lý ảnh
            let imgPreview = document.getElementById('m_ImagePreview');
            if (imgUrl && !imgUrl.includes('placehold.co')) {
                imgPreview.src = imgUrl;
                imgPreview.style.display = 'block';
            } else {
                imgPreview.style.display = 'none';
            }

            let hiddenDetails = document.getElementById('recipe-details-' + id);
            document.getElementById('m_RecipeFullDetails').innerHTML = hiddenDetails.innerHTML;

            document.getElementById('m_NewStatus').value = status;
            toggleReasonBox();

            let badge = document.getElementById('m_StatusBadge');
            if (status == 0) badge.innerHTML = '<span class="badge bg-warning text-dark px-3 py-2 fs-6">Chờ duyệt</span>';
            else if (status == 1) badge.innerHTML = '<span class="badge bg-success px-3 py-2 fs-6">Đã duyệt (Public)</span>';
            else if (status == 2) badge.innerHTML = '<span class="badge bg-danger px-3 py-2 fs-6">Đã Từ chối</span>';

            var firstTab = new bootstrap.Tab(document.getElementById('basic-tab'));
            firstTab.show();

            var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('editRecipeModal'));
            myModal.show();
        }

        function validateSubmit() {
            var statusVal = document.getElementById('m_NewStatus').value;
            var reason = document.getElementById('m_RejectReason').value.trim();

            if (statusVal === "2" && reason === "") {
                alert("Vui lòng nhập Ghi chú/Lý do để tác giả biết vì sao bị từ chối!");
                document.getElementById('m_RejectReason').focus();
                return false;
            }
            return true;
        }
    </script>
}