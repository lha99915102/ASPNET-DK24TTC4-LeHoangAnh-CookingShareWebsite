@{
    ViewBag.Title = "Góc bếp của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // 1. Nhận link hình nền to từ Controller (Nếu null thì dùng ảnh mặc định)
    string bgImage = ViewBag.CoverImage as string ?? "https://placehold.co/1200x400?text=My+Kitchen+Workspace";

    // 2. Nhận link ảnh Menu dự phòng từ Controller (Nếu null thì dùng mặc định)
    string fallbackMenuImg = ViewBag.FallbackMenuImg as string ?? "https://placehold.co/400x250?text=Menu+Hom+Nay";
}

<main class="bg-light py-5">
    <div class="container mb-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden text-white position-relative" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('@bgImage') center/cover no-repeat; min-height: 250px;">
            <div class="card-body p-4 p-md-5 text-center position-absolute top-50 start-50 translate-middle w-100">
                <h1 class="display-4 fw-bold mb-3" style="font-family: 'Dancing Script';">Góc Bếp Của Bạn</h1>
                <p class="lead mb-4">Chào mừng trở lại! Hôm nay bạn muốn nấu món gì hay cần hỗ trợ công cụ nào?</p>
                <a href="/Recipe/Grocery" class="btn btn-orange rounded-pill px-4 px-md-5 py-2 fw-bold shadow">
                    <i class="fas fa-shopping-basket me-2"></i> Mở Giỏ Đi Chợ Của Bạn
                </a>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row g-4">

            <div class="col-lg-8">
                <h4 class="fw-bold text-dark mb-4 border-start border-4 border-orange ps-3">Tiện ích nấu nướng</h4>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm rounded-4 hover-up bg-white">
                            <div class="card-body p-4 text-center">
                                <div class="icon-circle bg-info bg-opacity-10 text-info mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px;">
                                    <i class="fas fa-temperature-low fa-2x"></i>
                                </div>
                                <h5 class="fw-bold">Khám phá món ăn</h5>
                                <p class="text-secondary small">Gợi ý món ăn dựa trên nguyên liệu bạn đang có sẵn.</p>
                                <a href="/Recipe/Index" class="stretched-link"></a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm rounded-4 hover-up bg-white">
                            <div class="card-body p-4 text-center">
                                <div class="icon-circle bg-warning bg-opacity-10 text-warning mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width: 70px; height: 70px;">
                                    <i class="fas fa-lightbulb fa-2x"></i>
                                </div>
                                <h5 class="fw-bold">Mẹo Vặt Cuộc Sống</h5>
                                <p class="text-secondary small">Các bí kíp xử lý mùi, bảo quản thực phẩm và vệ sinh bếp.</p>
                                <a href="/Tip/Index" class="stretched-link"></a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="fw-bold mb-0 text-success"><i class="fas fa-exchange-alt me-2"></i>Chuyển đổi đơn vị bếp</h5>
                    </div>
                    <div class="card-body bg-light rounded-bottom-4">
                        <form id="converterForm">
                            <div class="row g-3 align-items-center">
                                <div class="col-md-3">
                                    <input type="number" class="form-control" id="inputValue" placeholder="Nhập số..." value="1" min="0" step="0.1">
                                </div>
                                <div class="col-md-3">
                                    <select class="form-select" id="inputUnit">
                                        <option value="cup">Cup (Cốc)</option>
                                        <option value="tbsp">Thìa canh (tbsp)</option>
                                        <option value="tsp">Thìa cà phê (tsp)</option>
                                        <option value="oz">Ounce (oz)</option>
                                    </select>
                                </div>
                                <div class="col-md-1 text-center">
                                    <i class="fas fa-arrow-right text-secondary"></i>
                                </div>
                                <div class="col-md-5">
                                    <div class="input-group">
                                        <input type="text" class="form-control bg-white fw-bold text-success" id="outputValue" readonly value="240">
                                        <span class="input-group-text bg-white">ml / gram</span>
                                    </div>
                                </div>
                            </div>
                        </form>
                        <p class="text-muted small mt-3 mb-0 fst-italic">* Công cụ giúp bạn quy đổi nhanh các đơn vị đo lường Âu/Mỹ sang chuẩn Việt Nam.</p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                        <div class="mb-3 mb-md-0">
                            <h5 class="fw-bold text-danger"><i class="fas fa-stopwatch me-2"></i>Đồng hồ đếm ngược</h5>
                            <p class="text-secondary small mb-0">Cần canh thời gian luộc trứng hay ủ bột?</p>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span id="timerDisplay" class="fw-bold fs-4 me-3 text-dark font-monospace">00:00</span>
                            <button type="button" class="btn btn-outline-secondary rounded-pill btn-set-time" data-time="180">3 phút</button>
                            <button type="button" class="btn btn-outline-secondary rounded-pill btn-set-time" data-time="300">5 phút</button>
                            <button type="button" class="btn btn-outline-secondary rounded-pill btn-set-time" data-time="900">15 phút</button>

                            <button type="button" class="btn btn-danger rounded-circle shadow-sm ms-2" id="btnPlayPause" style="width: 40px; height: 40px;">
                                <i class="fas fa-play" id="iconPlayPause"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <h4 class="fw-bold text-dark mb-4 border-start border-4 border-success ps-3">Hôm nay ăn gì?</h4>

                <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                    @{
                        var mainDish = ViewBag.MainDish as CookingShare.Models.RECIPE;
                        var soup = ViewBag.Soup as CookingShare.Models.RECIPE;
                        var dessert = ViewBag.Dessert as CookingShare.Models.RECIPE;

                        // 3. Xử lý ảnh bìa cho khối Menu:
                        // Ưu tiên dùng ảnh món Mặn, nếu không có thì dùng ảnh Dự phòng đã cấu hình
                        string coverImage = mainDish != null && !string.IsNullOrEmpty(mainDish.MainImage)
                                            ? mainDish.MainImage
                                            : fallbackMenuImg;
                    }

                    <div style="height: 200px; overflow: hidden;">
                        <img src="@coverImage" class="card-img-top w-100 h-100 object-fit-cover" alt="Menu" onerror="this.src='@fallbackMenuImg'">
                    </div>

                    <div class="card-body">
                        <h5 class="fw-bold text-success mb-3">Thực đơn gợi ý bạn nên thử</h5>

                        <ul class="list-group list-group-flush small mb-4">
                            <li class="list-group-item px-0 border-0 d-flex align-items-start">
                                <i class="fas fa-utensils text-orange mt-1 me-3" style="width: 16px;"></i>
                                <div>
                                    <span class="text-muted d-block" style="font-size: 0.75rem;">Món thứ nhất:</span>
                                    @if (mainDish != null)
                                    {
                                        <a href="/Recipe/Detail/@mainDish.ID" class="text-dark fw-bold text-decoration-none hover-orange">@mainDish.Name</a>
                                    }
                                    else
                                    { <span class="fst-italic text-secondary">Đang cập nhật...</span>}
                                </div>
                            </li>

                            <li class="list-group-item px-0 border-0 d-flex align-items-start">
                                <i class="fas fa-leaf text-success mt-1 me-3" style="width: 16px;"></i>
                                <div>
                                    <span class="text-muted d-block" style="font-size: 0.75rem;">Món thứ hai:</span>
                                    @if (soup != null)
                                    {
                                        <a href="/Recipe/Detail/@soup.ID" class="text-dark fw-bold text-decoration-none hover-orange">@soup.Name</a>
                                    }
                                    else
                                    { <span class="fst-italic text-secondary">Đang cập nhật...</span>}
                                </div>
                            </li>

                            <li class="list-group-item px-0 border-0 d-flex align-items-start">
                                <i class="fas fa-cookie text-warning mt-1 me-3" style="width: 16px;"></i>
                                <div>
                                    <span class="text-muted d-block" style="font-size: 0.75rem;">Món thứ ba: </span>
                                    @if (dessert != null)
                                    {
                                        <a href="/Recipe/Detail/@dessert.ID" class="text-dark fw-bold text-decoration-none hover-orange">@dessert.Name</a>
                                    }
                                    else
                                    { <span class="fst-italic text-secondary">Đang cập nhật...</span>}
                                </div>
                            </li>
                        </ul>

                        <a href="/Recipe/Index" class="btn btn-outline-success w-100 rounded-pill fw-bold">Khám phá món khác</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .hover-up {
        transition: transform 0.2s;
    }

        .hover-up:hover {
            transform: translateY(-5px);
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // ==========================================
        // 1. TÍNH NĂNG CHUYỂN ĐỔI ĐƠN VỊ BẾP
        // ==========================================
        const inpValue = document.getElementById('inputValue');
        const selUnit = document.getElementById('inputUnit');
        const outValue = document.getElementById('outputValue');

        function convertUnit() {
            let val = parseFloat(inpValue.value);
            if (isNaN(val)) {
                outValue.value = "0";
                return;
            }

            let unit = selUnit.value;
            let result = 0;

            // Tỉ lệ quy đổi
            if (unit === 'cup') result = val * 240;
            else if (unit === 'tbsp') result = val * 15;
            else if (unit === 'tsp') result = val * 5;
            else if (unit === 'oz') result = val * 28.35;

            outValue.value = result.toFixed(1).replace(/\.0$/, '');
        }

        inpValue.addEventListener('input', convertUnit);
        selUnit.addEventListener('change', convertUnit);


        // ==========================================
        // 2. TÍNH NĂNG ĐỒNG HỒ ĐẾM NGƯỢC (TIMER)
        // ==========================================
        let timerInterval;
        let timeLeft = 0;
        let isRunning = false;
        const display = document.getElementById('timerDisplay');
        const btnPlayPause = document.getElementById('btnPlayPause');
        const iconPlayPause = document.getElementById('iconPlayPause');
        const btnSetTimes = document.querySelectorAll('.btn-set-time');

        function updateDisplay(seconds) {
            let m = Math.floor(seconds / 60).toString().padStart(2, '0');
            let s = (seconds % 60).toString().padStart(2, '0');
            display.innerText = `${m}:${s}`;
        }

        function playSound() {
            let ctx = new (window.AudioContext || window.webkitAudioContext)();
            let osc = ctx.createOscillator();
            osc.type = "sine";
            osc.frequency.setValueAtTime(800, ctx.currentTime);
            osc.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + 0.5);
            setTimeout(() => { alert("⏰ Reng Reng! Hết thời gian rồi bạn ơi!"); }, 100);
        }

        function toggleTimer() {
            if (timeLeft <= 0) return;

            if (isRunning) {
                // Pause
                clearInterval(timerInterval);
                iconPlayPause.classList.remove('fa-pause');
                iconPlayPause.classList.add('fa-play');
                btnPlayPause.classList.replace('btn-secondary', 'btn-danger');
            } else {
                // Play
                iconPlayPause.classList.remove('fa-play');
                iconPlayPause.classList.add('fa-pause');
                btnPlayPause.classList.replace('btn-danger', 'btn-secondary');

                timerInterval = setInterval(() => {
                    timeLeft--;
                    updateDisplay(timeLeft);

                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        isRunning = false;
                        iconPlayPause.classList.remove('fa-pause');
                        iconPlayPause.classList.add('fa-play');
                        btnPlayPause.classList.replace('btn-secondary', 'btn-danger');
                        playSound();
                    }
                }, 1000);
            }
            isRunning = !isRunning;
        }

        btnSetTimes.forEach(btn => {
            btn.addEventListener('click', function () {
                clearInterval(timerInterval);
                isRunning = false;
                iconPlayPause.classList.remove('fa-pause');
                iconPlayPause.classList.add('fa-play');
                btnPlayPause.classList.replace('btn-secondary', 'btn-danger');

                timeLeft = parseInt(this.getAttribute('data-time'));
                updateDisplay(timeLeft);
            });
        });

        btnPlayPause.addEventListener('click', toggleTimer);

    });
</script>