@model CookingShare.Models.TIP

@{
    ViewBag.Title = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // XỬ LÝ ẢNH DỰ PHÒNG TỰ ĐỘNG
    string titleLower = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title.ToLower() : "";
    string firstChar = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title.Substring(0, 1).ToUpper() : "M";
    string bgColor = "ff6600"; // Cam mặc định

    if (titleLower.Contains("bảo quản") || titleLower.Contains("giữ"))
    {
        bgColor = "17a2b8"; // Xanh lơ
    }
    else if (titleLower.Contains("vệ sinh") || titleLower.Contains("sạch"))
    {
        bgColor = "dc3545"; // Đỏ
    }
    else if (titleLower.Contains("dinh dưỡng") || titleLower.Contains("calo"))
    {
        bgColor = "ffc107"; // Vàng
    }
    else if (titleLower.Contains("cách") || titleLower.Contains("mẹo"))
    {
        bgColor = "28a745"; // Xanh lá
    }

    // ĐÃ SỬA: Mã hóa an toàn ký tự đầu tiên
    string safeChar = System.Web.HttpUtility.UrlEncode(firstChar);
    string fallbackImg = $"https://placehold.co/1200x600/{bgColor}/FFFFFF?text={safeChar}";
    string imgSrc = fallbackImg;

    if (!string.IsNullOrWhiteSpace(Model.ImageURL))
    {
        if (!Model.ImageURL.StartsWith("/") && !Model.ImageURL.StartsWith("http"))
        {
            imgSrc = Url.Content("~/assets/images/tips/" + Model.ImageURL);
        }
        else
        {
            imgSrc = Model.ImageURL;
        }
    }

    // ĐÃ BỔ SUNG: Xử lý hiển thị thông tin Tác giả
    string authorName = Model.ACCOUNT != null ? Model.ACCOUNT.UserName : "Ban Biên Tập";
    string authorAva = Url.Content("~/assets/images/avatars/default-avatar.png");

    if (Model.ACCOUNT?.PROFILE != null)
    {
        if (!string.IsNullOrEmpty(Model.ACCOUNT.PROFILE.FullName)) { authorName = Model.ACCOUNT.PROFILE.FullName; }
        var ava = Model.ACCOUNT.PROFILE.Avatar;
        if (!string.IsNullOrEmpty(ava) && ava != "default-avatar.png")
        {
            authorAva = (ava.StartsWith("http") || ava.StartsWith("/")) ? ava : Url.Content("~/assets/images/avatars/" + ava);
        }
    }
}

<main class="bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">

            <div class="col-lg-9">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-decoration-none text-success">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Tip")" class="text-decoration-none text-success">Mẹo vặt</a></li>
                        <li class="breadcrumb-item active text-truncate" aria-current="page" style="max-width: 200px;">@Model.Title</li>
                    </ol>
                </nav>

                <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">

                    <img src="@imgSrc" onerror="this.onerror=null; this.src='@fallbackImg';"
                         class="card-img-top w-100 object-fit-cover" style="height: 400px;" alt="@Model.Title">

                    <div class="card-body p-4 p-md-5 bg-white">

                        <div class="text-center mb-5">
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill mb-3">Mẹo hay mỗi ngày</span>
                            <h1 class="fw-bold display-5 text-dark mb-4" style="line-height: 1.3;">@Model.Title</h1>

                            <div class="d-flex align-items-center justify-content-center text-muted small">
                                <img src="@authorAva" class="rounded-circle me-2 object-fit-cover border" style="width: 35px; height: 35px;" alt="@authorName" onerror="this.src='https://placehold.co/35x35/28a745/FFF?text=U'">
                                <span class="fw-bold text-dark me-3">@authorName</span>
                                <span><i class="far fa-calendar-alt me-1"></i> @(Model.CreateDate.HasValue ? Model.CreateDate.Value.ToString("dd/MM/yyyy") : "Đang cập nhật")</span>
                            </div>
                        </div>

                        <div class="post-content" style="font-size: 1.1rem; line-height: 1.8; color: #444;">
                            @Html.Raw(Model.Content)
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-light text-secondary border p-2">#KinhNghiemBep</span>
                                <span class="badge bg-light text-secondary border p-2">#MeoVat</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                <span class="text-muted small fw-bold me-2 d-none d-sm-block">Chia sẻ bài viết</span>
                                <button class="btn btn-outline-success btn-sm rounded-circle d-flex align-items-center justify-content-center" id="btn-copy-link" style="width: 35px; height: 35px;" title="Copy Link"><i class="fas fa-link"></i></button>
                            </div>
                        </div>

                    </div>
                </div>

                @if (ViewBag.RelatedTips != null)
                {
                    var relatedTips = ViewBag.RelatedTips as List<CookingShare.Models.TIP>;
                    if (relatedTips != null && relatedTips.Count > 0)
                    {
                        <div class="mt-5 mb-4">
                            <h4 class="fw-bold text-success mb-4 border-start border-4 border-success ps-3">Bài viết liên quan</h4>
                            <div class="row g-4">
                                @foreach (var rTip in relatedTips)
                                {
                                    string rFirstChar = !string.IsNullOrWhiteSpace(rTip.Title) ? rTip.Title.Substring(0, 1).ToUpper() : "M";
                                    string rFallbackImg = $"https://placehold.co/400x250/28a745/FFFFFF?text={System.Web.HttpUtility.UrlEncode(rFirstChar)}";
                                    string rImgSrc = rFallbackImg;

                                    if (!string.IsNullOrWhiteSpace(rTip.ImageURL))
                                    {
                                        rImgSrc = (rTip.ImageURL.StartsWith("http") || rTip.ImageURL.StartsWith("/")) ? rTip.ImageURL : Url.Content("~/assets/images/tips/" + rTip.ImageURL);
                                    }

                                    <div class="col-md-4">
                                        <div class="card h-100 border-0 shadow-sm rounded-3 hover-card">
                                            <a href="@Url.Action("Detail", "Tip", new { id = rTip.ID })" class="overflow-hidden rounded-top-3">
                                                <img src="@rImgSrc" class="card-img-top object-fit-cover tip-img" style="height: 160px; transition: transform 0.3s;" alt="@rTip.Title" onerror="this.onerror=null; this.src='@rFallbackImg';">
                                            </a>
                                            <div class="card-body p-3">
                                                <h6 class="fw-bold mb-0">
                                                    <a href="@Url.Action("Detail", "Tip", new { id = rTip.ID })" class="text-dark text-decoration-none custom-link-hover stretched-link text-truncate-2">@rTip.Title</a>
                                                </h6>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }

            </div>

        </div>
    </div>
</main>

<style>
    /* Rút gọn tiêu đề Mẹo liên quan */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* CSS làm đẹp cho nội dung bài viết */
    .post-content h2, .post-content h3 {
        color: #198754;
        font-weight: bold;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
    }

    .post-content img {
        max-width: 100%;
        height: auto;
        border-radius: 10px;
        margin: 1.5rem 0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .post-content blockquote {
        font-style: italic;
        color: #ff6600;
        border-left: 4px solid #ff6600;
        padding-left: 1rem;
        background-color: #fff5eb;
        padding: 1rem;
        border-radius: 0 10px 10px 0;
    }

    .hover-card:hover .tip-img {
        transform: scale(1.05);
    }

    .custom-link-hover:hover {
        color: #198754 !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Chức năng Copy link bài viết
        const copyBtn = document.getElementById('btn-copy-link');
        if (copyBtn) {
            copyBtn.addEventListener('click', function () {
                var dummy = document.createElement('input');
                document.body.appendChild(dummy);
                dummy.value = window.location.href; // Lấy URL hiện tại
                dummy.select();
                document.execCommand('copy');
                document.body.removeChild(dummy);

                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: 'Đã copy link bài viết!',
                        showConfirmButton: false,
                        timer: 2000
                    });
                } else {
                    alert("Đã copy link bài viết!");
                }
            });
        }
    });
</script>