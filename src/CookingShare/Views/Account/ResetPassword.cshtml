@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Khôi phục mật khẩu - CookingShare</title>
    <link rel="stylesheet" href="~/assets/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/assets/vendor/font-awesome/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card-auth {
            max-width: 450px;
            margin: 100px auto;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border: none;
        }

        /* CSS hỗ trợ cho nút Mắt và các input */
        .form-floating > .form-control:focus ~ label {
            color: #28a745;
        }

        .form-floating > .form-control:focus {
            border-color: #28a745;
            box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.25);
        }

        .cursor-pointer {
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card card-auth p-4 p-md-5">
            <div class="text-center mb-4">
                <h4 class="fw-bold">Tạo mật khẩu mới</h4>
                <p class="text-muted small">Mã OTP đã được gửi đến: <strong class="text-dark">@ViewBag.Email</strong></p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error</div>
            }

            <form action="@Url.Action("ResetPassword", "Account")" method="POST">
                @Html.AntiForgeryToken()

                <input type="hidden" name="email" value="@ViewBag.Email" />

                <div class="form-floating mb-3">
                    <input type="text" class="form-control fw-bold text-center" style="letter-spacing: 5px; font-size: 1.2rem;" id="otp" name="otp" placeholder="123456" required autocomplete="off" maxlength="6" pattern="\d{6}" inputmode="numeric" title="Vui lòng nhập đúng 6 chữ số">
                    <label for="otp">Nhập mã OTP (6 số)</label>
                </div>

                <div class="form-floating mb-3 position-relative">
                    <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="New Password" required>
                    <label for="newPassword">Mật khẩu mới</label>
                    <span class="position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer toggle-password" toggle="#newPassword" style="z-index: 10;">
                        <i class="far fa-eye text-secondary"></i>
                    </span>
                </div>

                <div class="form-floating mb-4 position-relative">
                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password" required>
                    <label for="confirmPassword">Nhập lại mật khẩu mới</label>
                    <span class="position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer toggle-password" toggle="#confirmPassword" style="z-index: 10;">
                        <i class="far fa-eye text-secondary"></i>
                    </span>
                </div>

                <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm">Xác nhận đổi mật khẩu</button>
            </form>

            <div class="text-center mt-4">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none text-secondary"><i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập</a>
            </div>
        </div>
    </div>

    <script src="~/assets/vendor/jquery/jquery.min.js"></script>
    <script>
        // Bổ sung Script cho tính năng ẩn/hiện mật khẩu
        $(".toggle-password").click(function () {
            $(this).find("i").toggleClass("fa-eye fa-eye-slash");
            var input = $($(this).attr("toggle"));
            if (input.attr("type") == "password") {
                input.attr("type", "text");
            } else {
                input.attr("type", "password");
            }
        });
    </script>
</body>
</html>