@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quên mật khẩu - CookingShare</title>
    <link rel="stylesheet" href="~/assets/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/assets/vendor/font-awesome/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card-auth {
            max-width: 450px;
            margin: 100px auto;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card card-auth p-4 p-md-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="font-family: 'Dancing Script', cursive; font-size: 3rem; color: #FF6600;">CookingShare</h2>
                <h4 class="fw-bold mt-3">Quên mật khẩu?</h4>
                <p class="text-muted">Nhập email của bạn, chúng tôi sẽ gửi mã xác nhận 6 chữ số để đặt lại mật khẩu.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error</div>
            }

            <form action="@Url.Action("ForgotPassword", "Account")" method="POST" id="forgotPwdForm">
                @Html.AntiForgeryToken()

                <div class="form-floating mb-4">
                    <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required>
                    <label for="email">Địa chỉ Email của bạn</label>
                </div>
                <button type="submit" id="btnSubmit" class="btn w-100 py-3 rounded-pill fw-bold shadow-sm" style="background-color: #FF6600; color: white;">
                    <i class="fas fa-paper-plane me-2"></i> Gửi mã xác nhận
                </button>
            </form>

            <div class="text-center mt-4">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none text-secondary"><i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById("forgotPwdForm").addEventListener("submit", function () {
            var btn = document.getElementById("btnSubmit");
            btn.disabled = true; // Khóa nút ngay lập tức
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Đang gửi mã...'; // Đổi trạng thái hiển thị
        });
    </script>
</body>
</html>