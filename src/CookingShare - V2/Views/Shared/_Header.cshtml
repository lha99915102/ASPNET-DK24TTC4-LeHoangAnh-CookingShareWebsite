<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
        <div class="container">

            <a class="navbar-brand navbar-brand-custom d-flex align-items-center" href="/Home/Index">
                <i class="fas fa-utensils me-2" style="color: #28a745;"></i>
                CookingShare
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                @{
                    // Lấy tên Controller đang chạy để biết người dùng đang ở trang nào
                    string currentController = ViewContext.RouteData.Values["controller"] as string ?? "Home";
                }

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" ? "active fw-bold text-success" : "")" href="/Home/Index">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Recipe" ? "active fw-bold text-success" : "")" href="/Recipe/Index">Công thức</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Kitchen" ? "active fw-bold text-success" : "")" href="/Kitchen/Index">Góc bếp</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Community" ? "active fw-bold text-success" : "")" href="/Community/Index">Cộng đồng</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center ms-lg-4 gap-2">

                    <a href="#" class="text-dark me-2 search-icon" id="search-trigger">
                        <i class="fas fa-search"></i>
                    </a>

                    <a href="/User/MyProfile" class="nav-link position-relative me-3 text-dark">
                        <i class="fas fa-bell fa-lg"></i>
                        @Html.Action("GetUnreadNotiBadge", "User")
                    </a>

                    @if (Session["Account"] == null)
                    {
                        <a href="/Account/Login" class="btn btn-outline-custom btn-sm rounded-pill px-3">Đăng nhập</a>
                        <a href="/Account/Register" class="btn btn-orange btn-sm rounded-pill px-3 shadow-sm">Đăng ký</a>
                    }
                    else
                    {
                        var currentUser = (CookingShare.Models.ACCOUNT)Session["Account"];
                        var userProfile = currentUser.PROFILE;

                        // Xử lý logic lấy ảnh Avatar cho Navbar
                        string navAvatar = "https://placehold.co/40x40/png?text=" + currentUser.UserName.Substring(0, 1).ToUpper();
                        if (userProfile != null && !string.IsNullOrEmpty(userProfile.Avatar))
                        {
                            navAvatar = "/assets/images/avatars/" + userProfile.Avatar;
                        }

                        <div class="d-flex align-items-center ms-lg-4 gap-2">
                            <div class="dropdown">
                                <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="@navAvatar" alt="User" class="rounded-circle border border-2 border-success me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                    <span class="fw-bold text-dark d-none d-md-inline">@(userProfile != null && !string.IsNullOrEmpty(userProfile.FullName) ? userProfile.FullName : currentUser.UserName)</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" href="/User/MyProfile"><i class="fas fa-user-circle me-2 text-success"></i>Trang cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </div>
                            <a href="/Recipe/Create" class="btn btn-orange btn-sm rounded-circle shadow-sm ms-2" title="Đăng công thức mới">
                                <i class="fas fa-plus"></i>
                            </a>
                            <a id="nav-cart-btn" href="/Recipe/Grocery" class="nav-link text-success position-relative ms-2" data-bs-toggle="tooltip" title="Giỏ đi chợ">
                                <i class="fas fa-shopping-basket fa-lg"></i>
                                @Html.Action("CartCount", "Recipe", new { area = "" })
                            </a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </nav>
</header>