@model CookingShare.Models.TIP

@{
    ViewBag.Title = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // XỬ LÝ ẢNH DỰ PHÒNG TỰ ĐỘNG
    string titleLower = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title.ToLower() : "";
    string firstChar = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title.Substring(0, 1).ToUpper() : "M";
    string bgColor = "ff6600"; // Cam mặc định

    if (titleLower.Contains("bảo quản") || titleLower.Contains("giữ"))
    {
        bgColor = "17a2b8"; // Xanh lơ
    }
    else if (titleLower.Contains("vệ sinh") || titleLower.Contains("sạch"))
    {
        bgColor = "dc3545"; // Đỏ
    }
    else if (titleLower.Contains("dinh dưỡng") || titleLower.Contains("calo"))
    {
        bgColor = "ffc107"; // Vàng
    }
    else if (titleLower.Contains("cách") || titleLower.Contains("mẹo"))
    {
        bgColor = "28a745"; // Xanh lá
    }

    // Kích thước ảnh ngang lớn cho trang detail (1200x600)
    string fallbackImg = $"https://placehold.co/1200x600/{bgColor}/FFFFFF?text={firstChar}";
    string imgSrc = !string.IsNullOrWhiteSpace(Model.ImageURL) ? $"/assets/images/tips/{Model.ImageURL}" : fallbackImg;
}

<main class="bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">

            <div class="col-lg-9">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-success">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a href="/Tip/Index" class="text-decoration-none text-success">Mẹo vặt</a></li>
                        <li class="breadcrumb-item active text-truncate" aria-current="page" style="max-width: 200px;">@Model.Title</li>
                    </ol>
                </nav>

                <div class="card border-0 shadow-sm rounded-4 mb-5 overflow-hidden">

                    <img src="@imgSrc" onerror="this.onerror=null; this.src='@fallbackImg';"
                         class="card-img-top w-100 object-fit-cover" style="height: 400px;" alt="@Model.Title">

                    <div class="card-body p-4 p-md-5 bg-white">

                        <div class="text-center mb-5">
                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill mb-3">Mẹo hay mỗi ngày</span>
                            <h1 class="fw-bold display-5 text-dark mb-3" style="line-height: 1.3;">@Model.Title</h1>

                            <div class="text-muted small">
                                <span><i class="far fa-calendar-alt me-1"></i> @(Model.CreateDate.HasValue ? Model.CreateDate.Value.ToString("dd/MM/yyyy") : "Đang cập nhật")</span>
                            </div>
                        </div>

                        <div class="post-content" style="font-size: 1.1rem; line-height: 1.8; color: #444;">
                            @Html.Raw(Model.Content)
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top">
                            <div class="d-flex gap-2">
                                <span class="badge bg-light text-secondary border p-2">#KinhNghiemBep</span>
                                <span class="badge bg-light text-secondary border p-2">#MeoVat</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted small fw-bold me-2">Chia sẻ
                                <button class="btn btn-outline-success btn-sm rounded-circle" id="btn-copy-link" style="width: 35px; height: 35px;" title="Copy Link"><i class="fas fa-link"></i></button>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div>
</main>

<style>
    /* CSS làm đẹp cho nội dung bài viết */
    .post-content h2, .post-content h3 {
        color: #198754;
        font-weight: bold;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
    }

    .post-content img {
        max-width: 100%;
        height: auto;
        border-radius: 10px;
        margin: 1.5rem 0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .post-content blockquote {
        font-style: italic;
        color: #ff6600;
        border-left: 4px solid #ff6600;
        padding-left: 1rem;
        background-color: #fff5eb;
        padding: 1rem;
        border-radius: 0 10px 10px 0;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Chức năng Copy link bài viết
        const copyBtn = document.getElementById('btn-copy-link');
        if (copyBtn) {
            copyBtn.addEventListener('click', function () {
                var dummy = document.createElement('input');
                document.body.appendChild(dummy);
                dummy.value = window.location.href; // Lấy URL hiện tại
                dummy.select();
                document.execCommand('copy');
                document.body.removeChild(dummy);

                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'success',
                        title: 'Đã copy link bài viết!',
                        showConfirmButton: false,
                        timer: 2000
                    });
                } else {
                    alert("Đã copy link bài viết!");
                }
            });
        }
    });
</script>