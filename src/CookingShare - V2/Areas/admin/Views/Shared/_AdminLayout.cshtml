<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Quản trị CookingShare</title>

    <link href="~/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/vendor/font-awesome/css/all.min.css">
    <script src="~/Areas/Admin/assets/vendor/chart/chart.umd.min.js"></script>
    <link href="~/Areas/Admin/assets/vendor/summernote/summernote-bs5.min.css" rel="stylesheet">
    <link href="~/Areas/Admin/assets/vendor/datatables/css/datatables.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Areas/Admin/assets/css/admin-style.css">
</head>
<body>

    <nav id="sidebar">
        <div class="sidebar-brand d-flex align-items-center">
            <i class="fas fa-utensils me-2" style="color: #28a745;"></i>
            CookingShare
        </div>

        <div class="sidebar-menu">
            <p class="menu-label">Tổng Quan</p>
            <a href="/Admin/Home/Index" class="active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>

            <p class="menu-label">Kiểm Duyệt</p>
            <a href="#">
                <i class="fas fa-book-open"></i> Công thức
            </a>
            <a href="#">
                <i class="fas fa-lightbulb"></i> Mẹo vặt
            </a>
            <a href="#">
                <i class="fas fa-layer-group"></i> Bộ sưu tập
            </a>
            <a href="#">
                <i class="fas fa-comment"></i> Bình luận
            </a>
            <a href="#"><i class="fas fa-users"></i> Cộng đồng & Report</a>

            <p class="menu-label">Dữ liệu gốc (Master Data)</p>

            <a href="#">
                <i class="fas fa-carrot" style="width: 25px;"></i> Nguyên liệu & Calo
            </a>

            <a href="#">
                <i class="fas fa-list" style="width: 25px;"></i> Danh mục Món ăn
            </a>

            <a href="#">
                <i class="fas fa-balance-scale" style="width: 25px;"></i> Đơn vị quy đổi
            </a>

            <a href="#">
                <i class="fas fa-tags" style="width: 25px;"></i> Tag & Chế độ ăn
            </a>

            <p class="menu-label">Hệ thống</p>
            <a href="#"><i class="fas fa-user-cog"></i> Người dùng</a>
            <a href="#"><i class="fas fa-images"></i> Quản lý Banner</a>
            <a href="#"><i class="fas fa-cogs"></i> Cấu hình Website</a>

            <div class="mt-5 px-3">
                <a href="/Admin/Auth/Logout" class="btn btn-outline-light w-100 text-start border-0">
                    <i class="fas fa-sign-out-alt text-danger"></i> Đăng xuất
                </a>
            </div>
        </div>
    </nav>

    <div id="content">

        <div class="top-navbar sticky-top">
            <div class="d-flex align-items-center">
                <button type="button" id="sidebarCollapse" class="btn btn-light border me-3">
                    <i class="fas fa-bars"></i>
                </button>
                <h4 class="mb-0 fw-bold text-secondary d-none d-md-block">Tổng quan hệ thống</h4>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="input-group d-none d-md-flex" style="width: 250px;">
                    <input type="text" class="form-control bg-light border-0" placeholder="Tìm kiếm nhanh...">
                    <button class="btn btn-light border-0"><i class="fas fa-search"></i></button>
                </div>

                <div class="dropdown">
                    <a href="#" class="text-secondary position-relative me-2" data-bs-toggle="dropdown">
                        <i class="fas fa-bell fa-lg"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                    </a>
                </div>

                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" data-bs-toggle="dropdown">
                        <img src="https://placehold.co/40x40" class="rounded-circle me-2" alt="Admin">
                        <div class="d-none d-md-block text-end me-1">
                            <span class="d-block text-muted" style="font-size: 0.7rem;">Super Admin</span>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li><a class="dropdown-item" href="#"><i class="fas fa-user-circle me-2"></i>Hồ sơ</a></li>
                        <li><a class="dropdown-item" href="#"><i class="fas fa-key me-2"></i>Đổi mật khẩu</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Admin/Auth/Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="container-fluid p-4">

            @RenderBody()

        </div>
    </div>

    <script src="~/assets/vendor/jquery/jquery.min.js"></script>
    <script src="~/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/Areas/Admin/assets/vendor/chart/chart.umd.min.js"></script>
    <script src="~/Areas/Admin/assets/vendor/summernote/summernote-bs5.min.js"></script>
    <script src="~/Areas/Admin/assets/vendor/datatables/js/datatables.min.js"></script>
    <script src="~/Areas/Admin/assets/js/admin-main.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
