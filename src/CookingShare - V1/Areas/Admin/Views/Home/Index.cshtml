@model IEnumerable<CookingShare.Models.RECIPE>

@{
    ViewBag.Title = "Tổng quan hệ thống";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card card h-100 border-start border-4 border-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1 text-uppercase fw-bold">Tổng Công thức</p>
                        <h3 class="fw-bold mb-0">850</h3>
                    </div>
                    <div class="icon-box bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-utensils"></i>
                    </div>
                </div>
                <small class="text-success small mt-2 d-block"><i class="fas fa-arrow-up"></i> +12 hôm nay</small>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="stat-card card h-100 border-start border-4 border-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1 text-uppercase fw-bold">Cần Duyệt Gấp</p>
                        <h3 class="fw-bold mb-0 text-danger">15</h3>
                    </div>
                    <div class="icon-box bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-tasks"></i>
                    </div>
                </div>
                <div class="mt-2 small">
                    <span class="badge bg-danger">10 Công thức</span>
                    <span class="badge bg-warning text-dark">5 Mẹo vặt</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="stat-card card h-100 border-start border-4 border-success">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1 text-uppercase fw-bold">Nguyên liệu (Gốc)</p>
                        <h3 class="fw-bold mb-0">1,204</h3>
                    </div>
                    <div class="icon-box bg-success bg-opacity-10 text-success">
                        <i class="fas fa-carrot"></i>
                    </div>
                </div>
                <small class="text-muted small mt-2 d-block">Đã chuẩn hóa Calo & Dị ứng</small>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="stat-card card h-100 border-start border-4 border-info">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1 text-uppercase fw-bold">Thành viên</p>
                        <h3 class="fw-bold mb-0">3,400</h3>
                    </div>
                    <div class="icon-box bg-info bg-opacity-10 text-info">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
                <small class="text-success small mt-2 d-block"><i class="fas fa-user-plus"></i> +50 tuần này</small>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-bolt me-2 text-warning"></i>Thao tác nhanh</h6>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="admin-settings.html" class="btn btn-outline-primary rounded-pill">
                        <i class="fas fa-images me-2"></i>Đổi Slider Trang Chủ
                    </a>
                    <a href="admin-settings.html" class="btn btn-outline-success rounded-pill">
                        <i class="fas fa-map-marked-alt me-2"></i>Cập nhật Map/Footer
                    </a>
                    <a href="admin-ingredients.html" class="btn btn-outline-warning rounded-pill">
                        <i class="fas fa-plus-circle me-2"></i>Thêm Nguyên Liệu Mới
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold border-bottom-0">
                <i class="fas fa-chart-area me-2 text-primary"></i>Thống kê truy cập & Bài đăng
            </div>
            <div class="card-body">
                <canvas id="mainChart" style="max-height: 350px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 fw-bold border-bottom-0 d-flex justify-content-between align-items-center">
                <span><i class="fas fa-bell me-2 text-danger"></i>Việc cần làm</span>
                <a href="admin-recipes.html" class="small text-decoration-none">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    <div class="list-group-item px-3 py-3 border-bottom-0 border-top">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px;">Phở Bò Gia Truyền</h6>
                            <span class="badge bg-light text-secondary border">Công thức</span>
                        </div>
                        <p class="mb-2 small text-secondary">Đăng bởi: <strong>TuanAnh</strong> • 10p trước</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success py-1 px-3" style="font-size: 0.75rem;">Duyệt</button>
                            <button class="btn btn-sm btn-outline-dark py-1 px-3" style="font-size: 0.75rem;">Xem</button>
                        </div>
                    </div>
                    <div class="list-group-item px-3 py-3 border-bottom-0 border-top">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px;">Mẹo giữ rau tươi lâu</h6>
                            <span class="badge bg-light text-secondary border">Mẹo vặt</span>
                        </div>
                        <p class="mb-2 small text-secondary">Đăng bởi: <strong>MeoMeo</strong> • 30p trước</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success py-1 px-3" style="font-size: 0.75rem;">Duyệt</button>
                            <button class="btn btn-sm btn-outline-dark py-1 px-3" style="font-size: 0.75rem;">Xem</button>
                        </div>
                    </div>
                    <div class="list-group-item px-3 py-3 border-bottom-0 border-top">
                        <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                            <h6 class="mb-0 fw-bold text-truncate" style="max-width: 150px;">Bún Đậu Mắm Tôm</h6>
                            <span class="badge bg-light text-secondary border">Công thức</span>
                        </div>
                        <p class="mb-2 small text-secondary">Đăng bởi: <strong>HungBungBu</strong> • 1h trước</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success py-1 px-3" style="font-size: 0.75rem;">Duyệt</button>
                            <button class="btn btn-sm btn-outline-dark py-1 px-3" style="font-size: 0.75rem;">Xem</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>