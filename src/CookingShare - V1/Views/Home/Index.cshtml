@model IEnumerable<CookingShare.Models.RECIPE>

@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var categories = ViewBag.Categories as List<CookingShare.Models.CATEGORY> ?? new List<CookingShare.Models.CATEGORY>();

    // Thuật toán tìm ID an toàn, không bị lỗi font Tiếng Việt
    int idMonMan = categories.FirstOrDefault(c => c.Name.Contains("Mặn"))?.ID ?? 0;
    int idMonChay = categories.FirstOrDefault(c => c.Name.Contains("Chay"))?.ID ?? 0;
    int idBanhNgot = categories.FirstOrDefault(c => c.Name.Contains("Bánh") || c.Name.Contains("Ngọt"))?.ID ?? 0;
    int idSinhTo = categories.FirstOrDefault(c => c.Name.Contains("Sinh"))?.ID ?? 0;
    int idDoNuong = categories.FirstOrDefault(c => c.Name.Contains("Nướng"))?.ID ?? 0;
}

<section class="hero-section mb-5">
    <div class="owl-carousel owl-theme" id="hero-slider">

        <div class="item position-relative">
            <img src="https://placehold.co/1920x600/212529/FFF?text=Banner+Mon+An" alt="Phở Bò" class="slider-img">
            <div class="slider-overlay d-flex align-items-center">
                <div class="container text-white text-center text-md-start">
                    <div class="row">
                        <div class="col-lg-8">
                            <span class="badge bg-orange mb-3 px-3 py-2 rounded-pill">Công thức mới</span>
                            <h1 class="display-3 fw-bold mb-3">Bí Quyết Nấu <br> <span class="text-success font-handwriting">Phở Bò Gia Truyền</span></h1>
                            <p class="lead mb-4">Hương vị đậm đà, nước dùng trong veo, chuẩn vị Hà Nội xưa ngay tại căn bếp của bạn.</p>
                            <a href="/Recipe/Index" class="btn btn-orange btn-lg rounded-pill px-5 shadow">Xem công thức</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="item position-relative">
            <img src="https://placehold.co/1920x600/5e35b1/FFF?text=Banner+Su+Kien" alt="Sự kiện" class="slider-img">
            <div class="slider-overlay d-flex align-items-center">
                <div class="container text-white text-center text-md-start">
                    <div class="row">
                        <div class="col-lg-8">
                            <span class="badge bg-warning text-dark mb-3 px-3 py-2 rounded-pill">Sự kiện Hot</span>
                            <h1 class="display-3 fw-bold mb-3">Cuộc Thi Ảnh <br> <span class="text-warning font-handwriting">"Bếp Ấm Ngày Tết"</span></h1>
                            <p class="lead mb-4">Chia sẻ mâm cơm ngày Tết của gia đình bạn để nhận ngay bộ nồi cao cấp trị giá 5 triệu đồng.</p>
                            <a href="/Community/Index" class="btn btn-light text-primary fw-bold btn-lg rounded-pill px-5 shadow">Tham gia ngay</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="item position-relative">
            <img src="https://placehold.co/1920x600/198754/FFF?text=Banner+Meo+Vat" alt="Mẹo vặt" class="slider-img">
            <div class="slider-overlay d-flex align-items-center">
                <div class="container text-white text-center text-md-start">
                    <div class="row">
                        <div class="col-lg-8">
                            <span class="badge bg-info text-white mb-3 px-3 py-2 rounded-pill">Mẹo nhà bếp</span>
                            <h1 class="display-3 fw-bold mb-3">5 Cách Bảo Quản <br> <span class="text-info font-handwriting">Rau Củ Tươi Lâu</span></h1>
                            <p class="lead mb-4">Rau héo úa là nỗi ám ảnh của mọi bà nội trợ. Xem ngay bí kíp giữ rau tươi cả tuần.</p>
                            <a href="/Tip/Index" class="btn btn-outline-light btn-lg rounded-pill px-5 shadow">Đọc bài viết</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<section class="container mb-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold section-title">Hôm nay ăn gì?</h2>
        <p class="text-muted">Đừng để câu hỏi này làm khó bạn. Tìm kiếm ý tưởng ngay!</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8 col-lg-6">
            <form action="/Recipe/Index" method="GET" class="position-relative search-box-wrapper">
                <input type="text" name="search" class="form-control form-control-lg rounded-pill ps-4 pe-5 border-2"
                       placeholder="Bạn đang thèm món gì? (VD: Sườn xào, Bánh mì...)"
                       style="height: 60px; font-size: 1rem;" autocomplete="off">

                <button type="submit" class="btn btn-orange rounded-pill position-absolute top-0 end-0 h-100 px-4 fw-bold"
                        style="z-index: 5;">
                    <i class="fas fa-search me-2"></i> Tìm kiếm
                </button>
            </form>
            <div class="text-center mt-2 small text-muted">
                <span>Gợi ý: </span>
                <a href="/Recipe/Index?search=Thịt+kho" class="text-decoration-none text-success fw-bold">Thịt kho tàu</a>,
                <a href="/Recipe/Index?search=Canh+chua" class="text-decoration-none text-success fw-bold">Canh chua</a>,
                <a href="/Recipe/Index?search=Eat+Clean" class="text-decoration-none text-success fw-bold">Eat Clean</a>
            </div>
        </div>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-6 col-md-4 col-lg-2 text-center">
            <a href="@(idMonMan > 0 ? "/Recipe/Index?categoryId=" + idMonMan : "/Recipe/Index?search=Món Mặn")" class="category-item d-block text-decoration-none">
                <div class="category-icon bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm">
                    <i class="fas fa-drumstick-bite fa-2x text-orange"></i>
                </div>
                <h6 class="fw-bold text-dark">Món Mặn</h6>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2 text-center">
            <a href="@(idMonChay > 0 ? "/Recipe/Index?categoryId=" + idMonChay : "/Recipe/Index?search=Món Chay")" class="category-item d-block text-decoration-none">
                <div class="category-icon bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm">
                    <i class="fas fa-carrot fa-2x text-success"></i>
                </div>
                <h6 class="fw-bold text-dark">Món Chay</h6>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2 text-center">
            <a href="@(idBanhNgot > 0 ? "/Recipe/Index?categoryId=" + idBanhNgot : "/Recipe/Index?search=Bánh Ngọt")" class="category-item d-block text-decoration-none">
                <div class="category-icon bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm">
                    <i class="fas fa-cookie-bite fa-2x text-warning"></i>
                </div>
                <h6 class="fw-bold text-dark">Bánh Ngọt</h6>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2 text-center">
            <a href="@(idSinhTo > 0 ? "/Recipe/Index?categoryId=" + idSinhTo : "/Recipe/Index?search=Sinh Tố")" class="category-item d-block text-decoration-none">
                <div class="category-icon bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm">
                    <i class="fas fa-blender fa-2x text-info"></i>
                </div>
                <h6 class="fw-bold text-dark">Sinh Tố</h6>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2 text-center">
            <a href="@(idDoNuong > 0 ? "/Recipe/Index?categoryId=" + idDoNuong : "/Recipe/Index?search=Đồ Nướng")" class="category-item d-block text-decoration-none">
                <div class="category-icon bg-light rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center shadow-sm">
                    <i class="fas fa-fire fa-2x text-danger"></i>
                </div>
                <h6 class="fw-bold text-dark">Đồ Nướng</h6>
            </a>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold section-title mb-0">Công Thức <span class="text-danger font-handwriting">(Mới Nhất)</span></h2>
            </div>
            <a href="/Recipe/Index" class="btn btn-outline-success rounded-pill btn-sm">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
        </div>

        <div class="row g-4">
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="card recipe-card h-100 border-0 shadow-sm">
                            <div class="position-relative">
                                @{
                                    string firstChar = !string.IsNullOrWhiteSpace(item.Name) ? item.Name.Substring(0, 1).ToUpper() : "M";
                                    string fallbackImg = $"https://placehold.co/400x300/ff6600/FFFFFF?text={firstChar}";
                                    string imgSrc = !string.IsNullOrWhiteSpace(item.MainImage) ? $"/assets/images/recipes/{item.MainImage}" : fallbackImg;
                                }
                                <img src="@imgSrc" onerror="this.onerror=null; this.src='@fallbackImg';" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                            </div>
                            <div class="card-body">
                                <div class="d-flex justify-content-between text-muted small mb-2">
                                    <span><i class="far fa-clock me-1"></i> @item.CookTime phút</span>
                                    <span><i class="fas fa-signal me-1"></i> @item.Difficulty</span>
                                </div>
                                <h5 class="card-title fw-bold">
                                    <a href="/Recipe/Detail/@item.ID" class="text-decoration-none text-dark stretched-link">@item.Name</a>
                                </h5>

                                @{
                                    string shortDesc = item.Describe ?? "";
                                    shortDesc = System.Text.RegularExpressions.Regex.Replace(shortDesc, "<.*?>", string.Empty);
                                    if (shortDesc.Length > 80) { shortDesc = shortDesc.Substring(0, 80) + "..."; }
                                }
                                <p class="card-text text-secondary small line-clamp-2">@shortDesc</p>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="cta-section py-5 position-relative text-white" style="background-color: #28a745; overflow: hidden;">
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: url('https://placehold.co/1920x400/1e7e34/1e7e34') center/cover; opacity: 0.2;"></div>

    <div class="container position-relative z-1 text-center">
        <h2 class="display-5 fw-bold mb-3 font-handwriting">Bạn Có Công Thức Bí Mật?</h2>
        <p class="lead mb-4">Chia sẻ công thức của bạn với hàng ngàn người yêu bếp khác. Cùng nhau xây dựng cộng đồng ẩm thực lớn nhất Việt Nam.</p>

        @if (Session["Account"] == null)
        {
            <a href="/Account/Register" class="btn btn-light btn-lg rounded-pill px-5 text-success fw-bold shadow">Đăng Ký Thành Viên Ngay</a>
        }
        else
        {
            <a href="/Recipe/Create" class="btn btn-light btn-lg rounded-pill px-5 text-success fw-bold shadow"><i class="fas fa-plus me-2"></i> Đăng Công Thức Ngay</a>
        }
    </div>
</section>