@model CookingShare.Models.ACCOUNT

@{
    ViewBag.Title = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var profile = Model.PROFILE;

    // Xử lý Avatar thông minh hỗ trợ Google Login và ký tự đặc biệt
    string safeChar = System.Web.HttpUtility.UrlEncode(Model.UserName.Substring(0, 1).ToUpper());
    string avatarUrl = $"https://placehold.co/100x100/28a745/FFF?text={safeChar}";

    if (profile != null && !string.IsNullOrEmpty(profile.Avatar) && profile.Avatar != "default-avatar.png")
    {
        avatarUrl = (profile.Avatar.StartsWith("http") || profile.Avatar.StartsWith("/"))
                    ? profile.Avatar
                    : Url.Content("~/assets/images/avatars/" + profile.Avatar);
    }
}

<main class="bg-light py-5">
    <div class="container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <div class="col-lg-3 mb-4">

                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body text-center pt-5 pb-4">

                        <div class="position-relative d-inline-block mb-3">
                            <div class="rounded-circle border border-3 border-success p-1 bg-white d-flex" style="width: 120px; height: 120px;">
                                <img id="avatar-preview" src="@avatarUrl" class="rounded-circle w-100 h-100 object-fit-cover" alt="Avatar" onerror="this.src='https://placehold.co/120x120/28a745/FFF?text=U'">
                            </div>

                            <button type="button" id="btn-change-avatar" class="btn btn-light rounded-circle position-absolute border shadow-sm d-flex align-items-center justify-content-center"
                                    style="bottom: 5px; right: 5px; width: 36px; height: 36px; padding: 0;" title="Đổi ảnh">
                                <i class="fas fa-camera text-secondary"></i>
                            </button>

                            <input type="file" id="AvatarUpload" name="AvatarFile" form="profileForm" class="d-none" accept="image/jpeg, image/png, image/jpg">
                        </div>

                        <h5 class="fw-bold mb-1">@(profile != null && !string.IsNullOrEmpty(profile.FullName) ? profile.FullName : Model.UserName)</h5>
                        <p class="text-muted small mb-3">@@@Model.UserName • Thành viên từ @(Model.RegistDate.HasValue ? Model.RegistDate.Value.Year.ToString() : "2026")</p>

                        <div class="d-flex justify-content-center gap-3 border-top pt-3">
                            <div class="text-center">
                                <span class="d-block fw-bold h6 mb-0">@Model.RECIPE.Count(r => r.Status == 1)</span>
                                <small class="text-secondary" style="font-size: 0.75rem">Công thức</small>
                            </div>
                            <div class="text-center">
                                <span class="d-block fw-bold h6 mb-0">@ViewBag.FollowerCount</span>
                                <small class="text-secondary" style="font-size: 0.75rem">Người theo dõi</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="list-group shadow-sm rounded-3 border-0" id="profile-tabs" role="tablist">
                    <a class="list-group-item list-group-item-action border-0 py-3 active fw-bold"
                       id="recipes-tab" data-bs-toggle="list" href="#my-recipes" role="tab">
                        <i class="fas fa-utensils me-3 text-orange"></i> Công thức của tôi
                        <span class="badge bg-light text-dark float-end rounded-pill border">@Model.RECIPE.Count()</span>
                    </a>

                    <a class="list-group-item list-group-item-action border-0 py-3 text-secondary"
                       id="favorites-tab" data-bs-toggle="list" href="#my-favorites" role="tab">
                        <i class="fas fa-heart me-3 text-danger"></i> Đã lưu / Yêu thích
                        <span class="badge bg-light text-dark float-end rounded-pill border" id="fav-count-badge">
                            @(ViewBag.Favorites != null ? ((List<CookingShare.Models.FAVORITE>)ViewBag.Favorites).Count : 0)
                        </span>
                    </a>

                    <a class="list-group-item list-group-item-action border-0 py-3 text-secondary"
                       id="notifications-tab" data-bs-toggle="list" href="#my-notifications" role="tab">
                        <i class="fas fa-bell me-3 text-warning"></i> Thông báo
                        @if (ViewBag.UnreadNotiCount > 0)
                        {
                            <span class="badge bg-danger float-end rounded-pill shadow-sm" id="noti-badge">@ViewBag.UnreadNotiCount</span>
                        }
                    </a>

                    <a class="list-group-item list-group-item-action border-0 py-3 text-secondary"
                       id="settings-tab" data-bs-toggle="list" href="#my-settings" role="tab">
                        <i class="fas fa-cog me-3 text-secondary"></i> Cài đặt tài khoản
                    </a>

                    <a href="@Url.Action("Logout", "Account")" class="list-group-item list-group-item-action border-0 py-3 text-danger">
                        <i class="fas fa-sign-out-alt me-3"></i> Đăng xuất
                    </a>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="tab-content" id="nav-tabContent">

                    <div class="tab-pane fade show active" id="my-recipes" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="fw-bold mb-0">Quản lý công thức</h3>
                            <a href="@Url.Action("Create", "Recipe")" class="btn btn-orange rounded-pill px-4 shadow-sm">
                                <i class="fas fa-plus me-2"></i> Viết bài mới
                            </a>
                        </div>

                        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
                            <div id="recipe-filters">
                                <button class="btn btn-sm btn-dark rounded-pill px-3 me-1 filter-btn" data-filter="all">Tất cả (@Model.RECIPE.Count())</button>
                                <button class="btn btn-sm btn-light border rounded-pill px-3 me-1 text-secondary filter-btn" data-filter="1">Đã duyệt (@Model.RECIPE.Count(r => r.Status == 1))</button>
                                <button class="btn btn-sm btn-light border rounded-pill px-3 text-secondary filter-btn" data-filter="0">Chờ duyệt (@Model.RECIPE.Count(r => r.Status != 1))</button>
                            </div>

                            <div class="d-flex align-items-center">
                                <span class="small text-muted me-2">Hiển thị:</span>
                                <select id="pageSizeSelect" class="form-select form-select-sm rounded-pill" style="width: auto;">
                                    <option value="6" selected>6 bài</option>
                                    <option value="10">10 bài</option>
                                    <option value="20">20 bài</option>
                                    <option value="50">50 bài (Tối đa)</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-4" id="recipe-list-container">
                            @if (Model.RECIPE.Count > 0)
                            {
                                foreach (var recipe in Model.RECIPE.OrderByDescending(r => r.CreateDate))
                                {
                                    <div class="col-md-6 recipe-item" data-status="@recipe.Status">
                                        <div class="card recipe-card h-100 border-0 shadow-sm">
                                            <div class="row g-0 h-100">
                                                <div class="col-4">
                                                    @{
                                                        string rFirstChar = !string.IsNullOrWhiteSpace(recipe.Name) ? recipe.Name.Substring(0, 1).ToUpper() : "R";
                                                        string rFallbackImg = $"https://placehold.co/200x200/ff6600/FFFFFF?text={System.Web.HttpUtility.UrlEncode(rFirstChar)}";
                                                        string rImgSrc = rFallbackImg;

                                                        if (!string.IsNullOrWhiteSpace(recipe.MainImage) && recipe.MainImage != "default_recipe.jpg")
                                                        {
                                                            rImgSrc = (recipe.MainImage.StartsWith("http") || recipe.MainImage.StartsWith("/"))
                                                                        ? recipe.MainImage
                                                                        : Url.Content("~/assets/images/recipes/" + recipe.MainImage);
                                                        }
                                                    }
                                                    <img src="@rImgSrc" class="img-fluid rounded-start h-100 object-fit-cover" alt="@recipe.Name" onerror="this.src='@rFallbackImg'">
                                                </div>
                                                <div class="col-8">
                                                    <div class="card-body py-2">
                                                        <h6 class="card-title fw-bold text-truncate mb-1">
                                                            <a href="@Url.Action("Detail", "Recipe", new { id = recipe.ID })" class="text-dark text-decoration-none">@recipe.Name</a>
                                                        </h6>
                                                        <p class="card-text small text-muted mb-2"><i class="far fa-clock"></i> @(recipe.CreateDate?.ToString("dd/MM/yyyy"))</p>

                                                        @if (recipe.Status == 1)
                                                        {<span class="badge bg-success-subtle text-success mb-2">Đã duyệt</span> }
                                                        else
                                                        { <span class="badge bg-warning-subtle text-warning mb-2">Chờ duyệt</span>}

                                                        <div class="mt-2">
                                                            <a href="@Url.Action("Edit", "Recipe", new { id = recipe.ID })" class="btn btn-sm btn-outline-primary rounded-pill me-1" title="Sửa bài"><i class="fas fa-edit"></i></a>
                                                            <a href="@Url.Action("Delete", "Recipe", new { id = recipe.ID })" onclick="return confirm('Bạn có chắc chắn muốn xóa công thức này? Hành động này không thể hoàn tác!');" class="btn btn-sm btn-outline-danger rounded-pill" title="Xóa bài"><i class="fas fa-trash"></i></a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div id="no-recipe-msg" class="text-center py-5 d-none">
                            <i class="fas fa-search fa-3x text-muted mb-3 opacity-50"></i>
                            <p class="text-muted">Không có công thức nào trong mục này.</p>
                        </div>

                        <nav class="mt-4 d-flex justify-content-center">
                            <ul class="pagination pagination-sm" id="recipe-pagination"></ul>
                        </nav>
                    </div>

                    <div class="tab-pane fade" id="my-favorites" role="tabpanel">
                        <h3 class="fw-bold mb-4">Bộ sưu tập yêu thích</h3>
                        <div class="row g-4" id="favorites-container">
                            @if (ViewBag.Favorites != null && ((List<CookingShare.Models.FAVORITE>)ViewBag.Favorites).Count > 0)
                            {
                                foreach (var fav in ViewBag.Favorites)
                                {
                                    <div class="col-md-4 fav-item">
                                        <div class="card recipe-card h-100 border-0 shadow-sm position-relative">
                                            @{
                                                string fFirstChar = !string.IsNullOrWhiteSpace(fav.RECIPE.Name) ? fav.RECIPE.Name.Substring(0, 1).ToUpper() : "R";
                                                string fFallbackImg = $"https://placehold.co/400x300/ff6600/FFFFFF?text={System.Web.HttpUtility.UrlEncode(fFirstChar)}";
                                                string fImgSrc = fFallbackImg;

                                                if (!string.IsNullOrWhiteSpace(fav.RECIPE.MainImage) && fav.RECIPE.MainImage != "default_recipe.jpg")
                                                {
                                                    fImgSrc = (fav.RECIPE.MainImage.StartsWith("http") || fav.RECIPE.MainImage.StartsWith("/"))
                                                                ? fav.RECIPE.MainImage
                                                                : Url.Content("~/assets/images/recipes/" + fav.RECIPE.MainImage);
                                                }
                                            }
                                            <img src="@fImgSrc" class="card-img-top object-fit-cover" style="height: 180px;" alt="@fav.RECIPE.Name" onerror="this.src='@fFallbackImg'">

                                            <div class="card-body p-3">
                                                <h6 class="card-title fw-bold mb-1 text-truncate">
                                                    <a href="@Url.Action("Detail", "Recipe", new { id = fav.RecipeID })" class="text-dark text-decoration-none stretched-link">@fav.RECIPE.Name</a>
                                                </h6>
                                                <small class="text-muted">Bởi @(fav.RECIPE.ACCOUNT != null ? fav.RECIPE.ACCOUNT.UserName : "Ẩn danh")</small>
                                            </div>
                                            <button type="button" class="btn btn-sm btn-light text-danger position-absolute top-0 end-0 m-2 rounded-circle shadow-sm btn-remove-fav" data-id="@fav.RecipeID" style="z-index: 2;" title="Bỏ lưu">
                                                <i class="fas fa-heart"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="col-12 text-center py-5 empty-fav-msg">
                                    <i class="fas fa-heart-broken fa-3x text-muted mb-3 opacity-50"></i>
                                    <p class="text-muted">Bạn chưa lưu công thức nào.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="tab-pane fade" id="my-notifications" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="fw-bold mb-0">Thông báo</h3>
                            <div>
                                <button id="btn-read-all-noti" class="btn btn-sm btn-link text-decoration-none">Đánh dấu đã đọc</button>
                                <span class="text-muted mx-1">|</span>
                                <button id="btn-delete-read-noti" class="btn btn-sm btn-link text-danger text-decoration-none" title="Chỉ xóa những thông báo đã đọc">
                                    <i class="fas fa-trash-alt me-1"></i> Xóa đã đọc
                                </button>
                            </div>
                        </div>

                        <div class="list-group border-0 shadow-sm rounded-3">
                            @if (ViewBag.Notifications != null && ((List<CookingShare.Models.NOTIFICATION>)ViewBag.Notifications).Count > 0)
                            {
                                foreach (var noti in ViewBag.Notifications)
                                {
                                    if (!string.IsNullOrEmpty(noti.LinkURL))
                                    {
                                        <a href="@Url.Action("ReadNotification", "User", new { id = noti.ID })" class="list-group-item list-group-item-action p-3 border-0 border-bottom @(noti.IsRead == false ? "bg-light" : "")">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0 text-success me-3"><i class="fas fa-bell fa-lg"></i></div>
                                                <div class="flex-grow-1">
                                                    <p class="mb-1 text-dark @(noti.IsRead == false ? "fw-bold" : "")">@noti.Content</p>
                                                    <small class="text-muted">@(noti.CreateDate?.ToString("dd/MM/yyyy HH:mm"))</small>
                                                </div>
                                                @if (noti.IsRead == false)
                                                {
                                                    <span class="badge bg-danger rounded-circle p-1" style="width: 10px; height: 10px;"></span>
                                                }
                                            </div>
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="list-group-item p-3 border-0 border-bottom @(noti.IsRead == false ? "bg-light" : "")">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-shrink-0 text-danger me-3"><i class="fas fa-exclamation-circle fa-lg"></i></div>
                                                <div class="flex-grow-1">
                                                    <p class="mb-1 text-dark @(noti.IsRead == false ? "fw-bold" : "")">@noti.Content</p>
                                                    <small class="text-muted">@(noti.CreateDate?.ToString("dd/MM/yyyy HH:mm"))</small>
                                                </div>
                                                @if (noti.IsRead == false)
                                                {
                                                    <span class="badge bg-danger rounded-circle p-1" style="width: 10px; height: 10px;"></span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <div class="p-4 text-center text-muted">Không có thông báo mới.</div>
                            }
                        </div>
                    </div>

                    <div class="tab-pane fade" id="my-settings" role="tabpanel">
                        <h3 class="fw-bold mb-4">Cài đặt tài khoản</h3>

                        <form id="profileForm" action="@Url.Action("UpdateProfile", "User")" method="POST" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-success mb-3"><i class="fas fa-user-circle me-2"></i>Thông tin tài khoản</h5>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Tên đăng nhập</label>
                                            <input type="text" class="form-control bg-light" value="@Model.UserName" readonly disabled>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Email</label>
                                            <input type="email" class="form-control bg-light" value="@Model.Email" readonly disabled>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Số điện thoại</label>
                                            <input type="text" class="form-control" name="Phone" value="@Model.Phone">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-success mb-3"><i class="fas fa-id-card me-2"></i>Thông tin cá nhân</h5>
                                    <h6 class="fw-bold text-success mb-3">(Nhập đủ các thông tin để hệ thống tính calo tiêu thụ)</h6>
                                    <div class="row g-3 mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Họ và tên</label>
                                            <input type="text" class="form-control" name="FullName" value="@(profile != null ? profile.FullName : "")" required>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold">Giới tính</label>
                                            <select class="form-select calo-trigger" id="inpGender" name="Gender">
                                                <option value="Nam" @(profile != null && profile.Gender == "Nam" ? "selected" : "")>Nam</option>
                                                <option value="Nữ" @(profile != null && profile.Gender == "Nữ" ? "selected" : "")>Nữ</option>
                                                <option value="Khác" @(profile != null && profile.Gender == "Khác" ? "selected" : "")>Khác</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold">Ngày sinh</label>
                                            <input type="date" class="form-control calo-trigger" id="inpBirthDay" name="BirthDay" value="@(profile != null && profile.BirthDay.HasValue ? profile.BirthDay.Value.ToString("yyyy-MM-dd") : "")">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold">Chiều cao (cm)</label>
                                            <input type="number" class="form-control calo-trigger" id="inpHeight" name="Height" placeholder="VD: 170" value="@(profile != null ? profile.Height : null)">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold">Cân nặng (kg)</label>
                                            <input type="number" step="0.1" class="form-control calo-trigger" id="inpWeight" name="Weight" placeholder="VD: 65" value="@(profile != null ? profile.Weight : null)">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold">Lối sống</label>
                                            <select class="form-select calo-trigger" id="inpLifestyle" name="Lifestyle">
                                                <option value="Ít vận động" @(profile != null && profile.Lifestyle == "Ít vận động" ? "selected" : "")>Ít vận động (Ngồi văn phòng)</option>
                                                <option value="Vận động nhẹ" @(profile != null && profile.Lifestyle == "Vận động nhẹ" ? "selected" : "")>Vận động nhẹ (Tập 1-3 ngày/tuần)</option>
                                                <option value="Vận động vừa" @(profile != null && profile.Lifestyle == "Vận động vừa" ? "selected" : "")>Vận động vừa (Tập 3-5 ngày/tuần)</option>
                                                <option value="Vận động nhiều" @(profile != null && profile.Lifestyle == "Vận động nhiều" ? "selected" : "")>Vận động nhiều (Tập 6-7 ngày/tuần)</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label small fw-bold text-success">Mục tiêu Calo/ngày</label>
                                            <input type="number" class="form-control bg-light text-success fw-bold" name="CaloDaily" id="CaloDaily" value="@(profile != null ? profile.CaloDaily : null)" readonly title="Hệ thống tự động tính">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-success mb-3"><i class="fas fa-utensils me-2"></i>Hồ sơ ẩm thực</h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Nghề nghiệp</label>
                                            <input type="text" class="form-control" name="JobTitle" value="@(profile != null ? profile.JobTitle : "")">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-bold">Học vấn</label>
                                            <input type="text" class="form-control" name="Education" value="@(profile != null ? profile.Education : "")">
                                        </div>
                                        <div class="col-md-12">
                                            <label class="form-label small fw-bold">Liên kết mạng xã hội (Facebook, Instagram...)</label>
                                            <input type="text" class="form-control" name="SocialLink" value="@(profile != null ? profile.SocialLink : "")">
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold">Giới thiệu ngắn (Bio)</label>
                                            <textarea class="form-control" name="Bio" rows="2" placeholder="Sẽ hiển thị ngay dưới tên của bạn trên trang cá nhân...">@(profile != null ? profile.Bio : "")</textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold">Triết lý nấu ăn</label>
                                            <textarea class="form-control" name="CookingPhilosophy" rows="2">@(profile != null ? profile.CookingPhilosophy : "")</textarea>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label small fw-bold">Ảnh không gian bếp của bạn (Kitchen Image)</label>
                                            <input type="file" class="form-control" name="KitchenFile" accept="image/jpeg, image/png, image/jpg">
                                            @if (profile != null && !string.IsNullOrEmpty(profile.KitchenImage))
                                            {
                                                <small class="text-muted d-block mt-1">Đã có ảnh. Tải lên ảnh mới để thay đổi.</small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-danger mb-3"><i class="fas fa-notes-medical me-2"></i>Hồ sơ sức khỏe & Dị ứng</h5>
                                    <p class="text-muted small">Chọn các thành phần bạn bị dị ứng. Chúng tôi sẽ tự động lưu lại.</p>

                                    <div class="input-group input-group-sm mb-3 w-50">
                                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="fas fa-search"></i></span>
                                        <input type="text" id="profileAllergySearch" class="form-control border-start-0 bg-light" placeholder="Gõ để tìm nhanh nguyên liệu...">
                                    </div>

                                    <div class="row g-3" id="profileAllergyList" style="max-height: 200px; overflow-y: auto;">
                                        @if (ViewBag.AllIngredients != null)
                                        {
                                            var myAllergies = (List<int>)ViewBag.UserAllergies;
                                            foreach (var ing in ViewBag.AllIngredients)
                                            {
                                                <div class="col-md-4 allergy-item-profile">
                                                    <div class="form-check bg-light p-3 rounded border h-100">
                                                        <input class="form-check-input" type="checkbox" name="AllergyIDs" value="@ing.ID" id="allergy_@ing.ID" @(myAllergies != null && myAllergies.Contains(ing.ID) ? "checked" : "")>
                                                        <label class="form-check-label fw-bold allergy-label-profile" for="allergy_@ing.ID">@ing.Name</label>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 mb-4">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-danger mb-3"><i class="fas fa-shield-alt me-2"></i>Đổi mật khẩu</h5>
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Mật khẩu cũ</label>
                                            <input type="password" class="form-control" name="OldPassword">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Mật khẩu mới</label>
                                            <input type="password" class="form-control" name="NewPassword">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label small fw-bold">Xác nhận</label>
                                            <input type="password" class="form-control" name="ConfirmPassword">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end sticky-bottom bg-light py-3 border-top mt-4" style="z-index: 10;">
                                <a href="@Url.Action("MyProfile", "User")" class="btn btn-light me-2">Hủy bỏ</a>
                                <button type="submit" class="btn btn-orange rounded-pill px-5 shadow fw-bold">Lưu tất cả thay đổi</button>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

        </div>
    </div>
</main>

<script>
    // XỬ LÝ ĐỔI ẢNH ĐẠI DIỆN (AVATAR)
    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById('btn-change-avatar').addEventListener('click', function () {
            document.getElementById('AvatarUpload').click();
        });

        document.getElementById('AvatarUpload').addEventListener('change', function (event) {
            const [file] = event.target.files;
            if (file) {
                document.getElementById('avatar-preview').src = URL.createObjectURL(file);
            }
        });
    });

    // XỬ LÝ NÚT "BỎ YÊU THÍCH"
    document.addEventListener("DOMContentLoaded", function () {
        const removeFavBtns = document.querySelectorAll('.btn-remove-fav');

        removeFavBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                if (!confirm("Bạn có muốn bỏ lưu công thức này không?")) return;

                let recipeId = this.getAttribute('data-id');
                let cardElement = this.closest('.fav-item');

                // Dùng Url.Action cho Fetch API
                fetch('@Url.Action("RemoveFavorite", "User")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'recipeId=' + recipeId
                })
                    .then(response => response.json())
                    .then(res => {
                        if (res.success) {
                            cardElement.style.transition = "opacity 0.3s ease";
                            cardElement.style.opacity = "0";
                            setTimeout(() => {
                                cardElement.remove();

                                let badge = document.getElementById('fav-count-badge');
                                let currentCount = parseInt(badge.innerText);
                                if (currentCount > 0) badge.innerText = currentCount - 1;

                                let remainingItems = document.querySelectorAll('.fav-item');
                                if (remainingItems.length === 0) {
                                    document.getElementById('favorites-container').innerHTML = `
                                    <div class="col-12 text-center py-5 empty-fav-msg">
                                        <i class="fas fa-heart-broken fa-3x text-muted mb-3 opacity-50"></i>
                                        <p class="text-muted">Bạn chưa lưu công thức nào.</p>
                                    </div>`;
                                }
                            }, 300);
                        } else {
                            alert("Có lỗi xảy ra, vui lòng thử lại.");
                        }
                    })
                    .catch(err => console.error("Lỗi bỏ thích:", err));
            });
        });
    });

    // XỬ LÝ NÚT THÔNG BÁO (ĐÁNH DẤU ĐÃ ĐỌC / XÓA)
    document.addEventListener("DOMContentLoaded", function () {
        const btnDeleteReadNoti = document.getElementById('btn-delete-read-noti');
        if (btnDeleteReadNoti) {
            btnDeleteReadNoti.addEventListener('click', function (e) {
                e.preventDefault();
                if (!confirm("Bạn có chắc chắn muốn dọn dẹp tất cả thông báo đã đọc?")) return;

                // ĐÃ SỬA: Dùng Url.Action cho Fetch API
                fetch('@Url.Action("DeleteReadNotifications", "User")', { method: 'POST' })
                    .then(response => response.json())
                    .then(res => {
                        if (res.success) {
                            const readItems = document.querySelectorAll('#my-notifications .list-group-item:not(.bg-light)');
                            readItems.forEach(item => {
                                item.style.transition = "opacity 0.3s ease";
                                item.style.opacity = "0";
                                setTimeout(() => item.remove(), 300);
                            });

                            setTimeout(() => {
                                const listContainer = document.querySelector('#my-notifications .list-group');
                                if (listContainer && listContainer.children.length === 0) {
                                    listContainer.innerHTML = '<div class="p-4 text-center text-muted">Không có thông báo mới.</div>';
                                }
                            }, 350);
                        }
                    });
            });
        }

        const btnReadAllNoti = document.getElementById('btn-read-all-noti');
        if (btnReadAllNoti) {
            btnReadAllNoti.addEventListener('click', function (e) {
                e.preventDefault();

                // Dùng Url.Action cho Fetch API
                fetch('@Url.Action("MarkNotificationsRead", "User")', { method: 'POST' })
                    .then(response => response.json())
                    .then(res => {
                        if (res.success) {
                            document.querySelectorAll('.badge.bg-danger.rounded-circle').forEach(el => el.classList.add('d-none'));
                            document.querySelectorAll('#my-notifications .bg-light').forEach(el => el.classList.remove('bg-light'));
                            document.querySelectorAll('#my-notifications .fw-bold').forEach(el => {
                                if (el.tagName.toLowerCase() === 'p') el.classList.remove('fw-bold');
                            });
                            const notiBadge = document.getElementById('noti-badge');
                            if (notiBadge) {
                                notiBadge.classList.add('d-none');
                            }
                        }
                    });
            });
        }
    });

    // XỬ LÝ LỌC VÀ PHÂN TRANG (PAGINATION) CHO CÔNG THỨC
    document.addEventListener("DOMContentLoaded", function () {
        const recipeItems = Array.from(document.querySelectorAll('.recipe-item'));
        const filterBtns = document.querySelectorAll('.filter-btn');
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        const paginationContainer = document.getElementById('recipe-pagination');
        const noRecipeMsg = document.getElementById('no-recipe-msg');

        let currentFilter = 'all';
        let currentPage = 1;
        let pageSize = parseInt(pageSizeSelect ? pageSizeSelect.value : 6);

        function renderRecipes() {
            let filteredRecipes = recipeItems.filter(item => {
                if (currentFilter === 'all') return true;
                return item.getAttribute('data-status') === currentFilter;
            });

            recipeItems.forEach(item => item.classList.add('d-none'));

            let totalItems = filteredRecipes.length;
            let totalPages = Math.ceil(totalItems / pageSize);

            if (currentPage > totalPages) currentPage = totalPages || 1;

            let startIndex = (currentPage - 1) * pageSize;
            let endIndex = Math.min(startIndex + pageSize, totalItems);

            if (totalItems > 0) {
                if (noRecipeMsg) noRecipeMsg.classList.add('d-none');
                for (let i = startIndex; i < endIndex; i++) {
                    filteredRecipes[i].classList.remove('d-none');
                    filteredRecipes[i].style.animation = "fadeIn 0.3s ease-in-out";
                }
            } else {
                if (noRecipeMsg) noRecipeMsg.classList.remove('d-none');
            }
            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            if (!paginationContainer) return;
            paginationContainer.innerHTML = '';
            if (totalPages <= 1) return;

            let prevClass = currentPage === 1 ? 'disabled d-none' : '';
            paginationContainer.innerHTML += `<li class="page-item custom-page-item ${prevClass}"><a class="page-link custom-page-link text-orange rounded-start-pill" href="#" data-page="${currentPage - 1}">Trước</a></li>`;

            for (let i = 1; i <= totalPages; i++) {
                let activeClass = currentPage === i ? 'active custom-active' : '';
                let textColor = currentPage === i ? 'text-white' : 'text-orange';
                paginationContainer.innerHTML += `<li class="page-item custom-page-item ${activeClass} mx-1"><a class="page-link custom-page-link ${textColor} rounded-circle border-0 fw-bold d-flex justify-content-center align-items-center" style="width: 40px; height: 40px;" href="#" data-page="${i}">${i}</a></li>`;
            }

            let nextClass = currentPage === totalPages ? 'disabled d-none' : '';
            paginationContainer.innerHTML += `<li class="page-item custom-page-item ${nextClass}"><a class="page-link custom-page-link text-orange rounded-end-pill" href="#" data-page="${currentPage + 1}">Sau</a></li>`;
        }

        if (filterBtns) {
            filterBtns.forEach(btn => {
                btn.addEventListener('click', function () {
                    filterBtns.forEach(b => {
                        b.classList.remove('btn-dark');
                        b.classList.add('btn-light', 'text-secondary');
                    });
                    this.classList.remove('btn-light', 'text-secondary');
                    this.classList.add('btn-dark');

                    currentFilter = this.getAttribute('data-filter');
                    currentPage = 1;
                    renderRecipes();
                });
            });
        }

        if (pageSizeSelect) {
            pageSizeSelect.addEventListener('change', function () {
                pageSize = parseInt(this.value);
                currentPage = 1;
                renderRecipes();
            });
        }

        if (paginationContainer) {
            paginationContainer.addEventListener('click', function (e) {
                e.preventDefault();
                if (e.target.tagName === 'A' && !e.target.parentElement.classList.contains('disabled')) {
                    currentPage = parseInt(e.target.getAttribute('data-page'));
                    renderRecipes();
                    document.getElementById('recipe-filters').scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        }

        renderRecipes();
    });

    // XỬ LÝ TỰ ĐỘNG TÍNH CALO HẰNG NGÀY (TDEE) BẰNG ID ĐỘC LẬP
    document.addEventListener("DOMContentLoaded", function () {
        const triggers = document.querySelectorAll('.calo-trigger');
        const caloInput = document.getElementById('CaloDaily');

        function calculateCalories() {
            if (!caloInput) return;

            let weightStr = document.getElementById('inpWeight').value;
            let heightStr = document.getElementById('inpHeight').value;
            let gender = document.getElementById('inpGender').value;
            let dobString = document.getElementById('inpBirthDay').value;
            let lifestyle = document.getElementById('inpLifestyle').value;

            // KIỂM TRA RỖNG VÀ NHẮC NHỞ NGƯỜI DÙNG
            if (!dobString || !heightStr || !weightStr) {
                caloInput.value = '';

                // Đổi chữ mờ để nhắc người dùng thiếu cái gì
                if (!dobString) caloInput.placeholder = "Thiếu Ngày sinh...";
                else if (!heightStr) caloInput.placeholder = "Thiếu Chiều cao...";
                else if (!weightStr) caloInput.placeholder = "Thiếu Cân nặng...";

                return;
            }

            // Nếu đủ thông tin, xóa placeholder đi
            caloInput.placeholder = "";

            let weight = parseFloat(weightStr);
            let height = parseFloat(heightStr);

            // Tính tuổi
            let dob = new Date(dobString);
            let today = new Date();
            let age = today.getFullYear() - dob.getFullYear();
            let m = today.getMonth() - dob.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) {
                age--;
            }

            // Công thức Mifflin-St Jeor
            let bmr = (10 * weight) + (6.25 * height) - (5 * age);

            if (gender === 'Nam') {
                bmr += 5;
            } else if (gender === 'Nữ') {
                bmr -= 161;
            } else {
                bmr -= 78;
            }

            // Hệ số Lối sống
            let multiplier = 1.2;
            if (lifestyle === 'Vận động nhẹ') multiplier = 1.375;
            else if (lifestyle === 'Vận động vừa') multiplier = 1.55;
            else if (lifestyle === 'Vận động nhiều') multiplier = 1.725;

            let tdee = Math.round(bmr * multiplier);

            if (tdee > 0) {
                caloInput.value = tdee;
            }
        }

        // Gắn sự kiện lắng nghe
        triggers.forEach(el => {
            el.addEventListener('input', calculateCalories);
            el.addEventListener('change', calculateCalories);
        });

        // Chạy ngay khi load trang
        calculateCalories();
    });

    // TÍNH NĂNG LỌC NHANH NGUYÊN LIỆU (TAB CÀI ĐẶT DỊ ỨNG)
    document.addEventListener("DOMContentLoaded", function () {
        const profileAllergySearch = document.getElementById('profileAllergySearch');
        if (profileAllergySearch) {

            // Ngăn chặn bấm Enter bị văng form
            profileAllergySearch.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') e.preventDefault();
            });

            // Xử lý khi gõ phím
            profileAllergySearch.addEventListener('keyup', function () {
                let filterText = this.value.toLowerCase();
                let items = document.querySelectorAll('.allergy-item-profile');

                items.forEach(item => {
                    let labelText = item.querySelector('.allergy-label-profile').innerText.toLowerCase();

                    // Nếu tên nguyên liệu chứa chữ vừa gõ -> Hiện lên, ngược lại -> Giấu đi
                    if (labelText.includes(filterText)) {
                        item.style.display = "";
                    } else {
                        item.style.display = "none";
                    }
                });
            });
        }
    });

</script>

